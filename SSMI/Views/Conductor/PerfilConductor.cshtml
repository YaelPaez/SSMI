@model SSMI.Models.ViewModels.CompletarPerfilViewModel
@* Nota: Puedes cambiar el @model si usas una entidad directa como SSMI.Models.Conductor o similar *@

@{
    Layout = "~/Views/Shared/_UsuarioLayout.cshtml";
    ViewData["Title"] = "Mi Perfil de Conductor";
}

<style>
    /* ── Contenido perfil ── */
    .contenido-perfil {
        flex-grow: 1;
        overflow-y: auto;
        padding: 1.5rem;
        transition: background .3s;
    }

    /* ── Avatar Conductor ── */
    .circulo-avatar {
        width: 110px;
        height: 110px;
        border-radius: 50%;
        background: linear-gradient(135deg, #1E3C54, #00d4ff);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem auto;
        box-shadow: 0 8px 25px rgba(0,212,255,.25);
        transition: box-shadow .3s;
    }

        .circulo-avatar svg {
            width: 58px;
            fill: #fff;
        }

    /* ── Nombre ── */
    .nombre-perfil {
        font-size: calc(var(--font-size-base, 1rem) * 1.45);
        font-weight: 800;
        color: #1E3C54;
        text-align: center;
        margin-bottom: .25rem;
        transition: color .3s;
    }

    .subtitulo-perfil {
        text-align: center;
        font-size: calc(var(--font-size-base, 1rem) * 0.85);
        color: #8b949e;
        margin-bottom: 1.75rem;
    }

    /* ── Tarjetas de información ── */
    .tarjeta-dato {
        background: #fff;
        border-radius: 16px;
        padding: 1rem 1.25rem;
        margin-bottom: .85rem;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
        display: flex;
        align-items: center;
        gap: 1rem;
        transition: background .3s, box-shadow .3s, transform .2s;
    }

        .tarjeta-dato:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0,0,0,.09);
        }

    .icono-dato {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        background: rgba(0,212,255,.1);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #00d4ff;
        font-size: 1.1rem;
        flex-shrink: 0;
        transition: background .3s;
    }

    .etiqueta-dato {
        font-size: calc(var(--font-size-base, 1rem) * 0.72);
        text-transform: uppercase;
        letter-spacing: .1em;
        color: #8b949e;
        margin-bottom: .1rem;
        font-weight: 600;
    }

    .valor-dato {
        font-size: var(--font-size-base, 1rem);
        font-weight: 600;
        color: #1E3C54;
        transition: color .3s;
    }

        .valor-dato.vacio {
            color: #adb5bd;
            font-weight: 400;
            font-style: italic;
        }

    /* ── Historial o Rutas ── */
    .tarjeta-viajes {
        background: #fff;
        border-radius: 16px;
        padding: 1.25rem;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
        transition: background .3s;
    }

    .titulo-viajes {
        font-size: calc(var(--font-size-base, 1rem) * 0.72);
        text-transform: uppercase;
        letter-spacing: .1em;
        color: #8b949e;
        font-weight: 700;
        margin-bottom: .75rem;
    }

    .texto-vacio {
        color: #adb5bd;
        font-size: calc(var(--font-size-base, 1rem) * 0.88);
        font-style: italic;
    }

    /* ── Modo oscuro específico de esta vista ── */
    body.dark-mode .circulo-avatar {
        box-shadow: 0 8px 25px rgba(0,212,255,.4);
    }

    body.dark-mode .nombre-perfil {
        color: #e6edf3;
    }

    body.dark-mode .tarjeta-dato {
        background: #161b22;
        box-shadow: 0 2px 12px rgba(0,0,0,.3);
    }

        body.dark-mode .tarjeta-dato:hover {
            box-shadow: 0 6px 20px rgba(0,0,0,.45);
        }

    body.dark-mode .icono-dato {
        background: rgba(0,212,255,.14);
    }

    body.dark-mode .valor-dato {
        color: #e6edf3;
    }

    body.dark-mode .tarjeta-viajes {
        background: #161b22;
    }
</style>

<div class="menu-container d-flex app-viewport">

    <div id="sidebarMenu" class="shadow">
        <div class="d-flex flex-column p-4 h-100">
            <h4 class="text-center mt-2 mb-4">SSMI Conductor</h4>
            <a asp-controller="Conductor" asp-action="Index" class="nav-btn">
                <i class="bi bi-bus-front"></i> Index
            </a>

            <a asp-controller="Conductor" asp-action="MiUnidad" class="nav-btn active">
                <i class="bi bi-bus-front"></i> Mi Unidad
            </a>

            <a asp-controller="Conductor" asp-action="Incidencias" class="nav-btn">
                <i class="bi bi-bus-front"></i> Incidencias
            </a>
            <div class="mt-auto">
                <a asp-controller="Usuario" asp-action="Ayuda" class="nav-btn">
                    <i class="bi bi-question-circle"></i> Ayuda
                </a>
                <a asp-controller="Usuario" asp-action="AcercaDeNosotros" class="nav-btn">
                    <i class="bi bi-question-circle"></i> Acerca de Nosotros
                </a>
                <a asp-controller="Login" asp-action="CerrarSesion" class="nav-btn"><i class="bi bi-box-arrow-right"></i> Cerrar Sesión</a>

            </div>
        </div>
    </div>

    <div class="d-flex flex-column w-100 overflow-hidden">
        <div class="p-3">
            <button id="btnToggleMenu" class="btn rounded-circle shadow-sm">
                <i class="bi bi-list fs-5"></i>
            </button>
        </div>

        <div class="contenido-perfil">
            <div style="max-width:480px; margin:0 auto;">

                <div class="circulo-avatar">
                    <svg viewBox="0 0 24 24">
                        <path d="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z" />
                    </svg>
                </div>
                <div class="nombre-perfil">
                    @(Model?.ApellidoPaterno != null ? Model.ApellidoPaterno.ToUpper() + " " + Model.ApellidoMaterno.ToUpper() : "Conductor")
                </div>
                <div class="subtitulo-perfil">@(Model?.Email ?? "conductor@ssmi.mx")</div>

                <div class="tarjeta-dato">
                    <div class="icono-dato"><i class="bi bi-envelope"></i></div>
                    <div>
                        <div class="etiqueta-dato">Usuario / Correo</div>
                        <div class="valor-dato">@(Model?.Email ?? "Sin datos")</div>
                    </div>
                </div>

                <div class="tarjeta-dato">
                    <div class="icono-dato"><i class="bi bi-person-badge"></i></div>
                    <div>
                        <div class="etiqueta-dato">Apellidos</div>
                        <div class="valor-dato @(Model?.ApellidoPaterno == null ? "vacio" : "")">
                            @(Model?.ApellidoPaterno != null ? Model.ApellidoPaterno + " " + Model.ApellidoMaterno : "Sin datos")
                        </div>
                    </div>
                </div>

                <div class="tarjeta-dato">
                    <div class="icono-dato"><i class="bi bi-building"></i></div>
                    <div>
                        <div class="etiqueta-dato">Empresa de Transporte</div>
                        <div class="valor-dato @(Model?.Empresa == null ? "vacio" : "")">
                            @(Model?.Empresa ?? "Sin empresa asignada")
                        </div>
                    </div>
                </div>

                <div class="tarjeta-viajes">
                    <div class="titulo-viajes"><i class="bi bi-speedometer2 me-2"></i>Turnos y Rutas Recientes</div>
                    <div class="texto-vacio">No has registrado incidencias ni viajes en el turno actual.</div>
                </div>

              

            </div>
        </div>
    </div>
</div>

@section Scripts {
}