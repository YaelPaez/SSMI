@model SSMI.Models.ViewModels.IncidenciaViewModel

@{
    ViewData["Title"] = "Incidencias";
    Layout = "~/Views/Shared/_UsuarioLayout.cshtml";

}

<style>
    :root {
        --primary: #1E3C54;
        --accent: #00d4ff;
        --font-size-base: 1rem;
    }

    /* ───── CONTENEDOR PRINCIPAL ───── */
    .app-viewport {
        min-height: 100vh;
        background-color: #f0f2f5;
        display: flex;
        align-items: stretch;
        overflow-x: hidden;
        transition: background-color .3s;
    }

    /* ───── SIDEBAR ───── */
    #sidebarMenu {
        width: 280px;
        background-color: #1E3C54 !important;
        position: sticky;
        top: 0;
        height: 100vh;
        transition: margin-left 0.3s ease-in-out, visibility 0.3s, background-color .3s;
        z-index: 1000;
        flex-shrink: 0;
    }

        #sidebarMenu.collapsed {
            margin-left: -280px;
            visibility: hidden;
        }

        #sidebarMenu h4 {
            color: #00d4ff;
            font-weight: 800;
            letter-spacing: 1px;
        }

    .nav-btn {
        text-align: left;
        padding: 12px 20px;
        border-radius: 12px !important;
        margin-bottom: 8px;
        transition: 0.3s;
        border: none !important;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 12px;
        color: rgba(255,255,255,0.8);
        background: transparent;
        text-decoration: none;
    }

        .nav-btn:hover {
            background: rgba(255,255,255,0.1);
            color: #ffffff;
            transform: translateX(5px);
        }

        .nav-btn.active {
            background: #ffffff !important;
            color: #1E3C54 !important;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }

    /* ───── CONTENIDO ───── */
    .main-content {
        flex-grow: 1;
        padding: 2rem;
        transition: all 0.3s ease-in-out;
    }

    .unit-card {
        background: white;
        border-radius: 20px;
        padding: 2.5rem;
        box-shadow: 0 10px 25px rgba(0,0,0,0.05);
        max-width: 800px;
        margin: 0 auto;
        transition: background-color .3s, border .3s, box-shadow .3s;
    }

    .unit-header {
        margin-bottom: 2rem;
        border-bottom: 1px solid #eee;
        padding-bottom: 1rem;
    }

    .unit-title {
        font-size: 1.8rem;
        font-weight: 800;
        color: var(--primary);
    }

    .unit-item {
        margin-bottom: 1.5rem;
    }

    .unit-label {
        font-weight: 700;
        color: #4b5563;
        margin-bottom: 8px;
        display: block;
    }

    /* Inputs estilizados como el segundo código */
    .form-control-custom {
        width: 100%;
        padding: 12px 15px;
        border-radius: 12px;
        border: 2px solid #e9ecef;
        background-color: #ffff;
        transition: all 0.3s;
        color: #1f2937;
        appearance: none;
        -webkit-appearance: none;
        -moz-appearance: none;
    }

        .form-control-custom:focus {
            outline: none;
            border-color: var(--accent);
            box-shadow: 0 0 0 0.25rem rgba(0, 212, 255, 0.1);
        }

        .form-control-custom option {
            background-color: #ffff;
            color: #1f2937;
            padding: 10px;
        }

    .unit-actions {
        margin-top: 2.5rem;
        display: flex;
        gap: 1rem;
    }

    .btn-unit {
        flex: 1;
        padding: 12px;
        border: none;
        border-radius: 12px;
        font-weight: 700;
        cursor: pointer;
        transition: 0.3s;
    }

    .btn-primary-unit {
        background: var(--primary);
        color: white;
    }

    .btn-secondary-unit {
        background: #e5e7eb;
        color: #4b5563;
    }

    .btn-unit:hover {
        transform: translateY(-2px);
        opacity: 0.9;
    }

    /* ───── MODO OSCURO (Sincronizado con el segundo código) ───── */
    html.dark-mode .app-viewport {
        background-color: #0d1117 !important;
    }

    html.dark-mode #sidebarMenu {
        background-color: #161b22 !important;
        border-right: 1px solid rgba(0,212,255,.15);
    }

    html.dark-mode .unit-card {
        background-color: #161b22 !important;
        border: 1px solid rgba(0,212,255,.12);
        box-shadow: 0 10px 25px rgba(0,0,0,.4);
    }

    html.dark-mode .unit-title,
    html.dark-mode .unit-label {
        color: #e6edf3 !important;
    }

    html.dark-mode .unit-header {
        border-bottom-color: rgba(255,255,255,0.1);
    }

    html.dark-mode .form-control-custom {
        background-color: rgba(0,212,255,.06) !important;
        border-color: rgba(0,212,255,.2) !important;
        color: #e6edf3 !important;
    }

        html.dark-mode .form-control-custom option {
            background-color: #0d1117;
            color: #00d4ff;
        }

        html.dark-mode .form-control-custom::placeholder {
            color: #8b949e;
        }

    html.dark-mode .btn-primary-unit {
        background-color: #00d4ff;
        color: #0d1117;
    }

    html.dark-mode .btn-secondary-unit {
        background-color: #21262d;
        color: #8b949e;
    }

    html.dark-mode small {
        color: #8b949e !important;
    }

    @@media (max-width: 768px) {
        .unit-actions {
            flex-direction: column;
        }
    }
</style>

<div class="app-viewport">
    <div id="sidebarMenu" class="shadow">
        <div class="d-flex flex-column p-4 h-100">
            <h4 class="text-center mt-2 mb-4">SSMI</h4>

            <a asp-controller="Conductor" asp-action="Index" class="nav-btn active">
                <i class="bi bi-bus-front"></i> Index
            </a>

            <a asp-controller="Conductor" asp-action="MiUnidad" class="nav-btn active">
                <i class="bi bi-bus-front"></i> Mi Unidad
            </a>

            <a asp-controller="Conductor" asp-action="Incidencias" class="nav-btn active">
                <i class="bi bi-bus-front"></i> Incidencias
            </a>

            <div class="mt-auto">
                <a asp-controller="Usuario" asp-action="Ayuda" class="nav-btn">
                    <i class="bi bi-question-circle"></i> Ayuda
                </a>
                <a asp-controller="Usuario" asp-action="AcercaDeNosotros" class="nav-btn">
                    <i class="bi bi-question-circle"></i> Acerca de Nosotros
                </a>
            </div>
        </div>
    </div>

    <div class="main-content">
        <div class="mb-4">
            <button id="btnToggleMenu" class="btn btn-dark rounded-circle shadow-sm"
                    style="background-color: #1E3C54; border-color: #00d4ff; width:45px; height:45px;">
                <i class="bi bi-list"></i>
            </button>
        </div>

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <form class="unit-card" method="post" enctype="multipart/form-data">
            <div class="unit-header text-center">
                <h2 class="unit-title">Reporte de Incidente</h2>
            </div>

            <div class="unit-item">
                <label class="unit-label" for="incidente">Tipo de Incidente</label>
                <select asp-for="Incidente" id="Incidente" class="form-control-custom">
                    <option value="">Selecciona un incidente</option>
                    <option value="choque">Choque</option>
                    <option value="refaccionaria_danada">Refaccionaria dañada</option>
                    <option value="otro">Otro</option>
                </select>
                <span asp-validation-for="Incidente" class="text-danger"></span>
                <input asp-for="Otro" id="otro" class="form-control-custom mt-3" placeholder="Especifica el incidente" style="display:none;">
                <span asp-validation-for="Otro" class="text-danger"></span>
            </div>

            <div class="unit-item">
                <label class="unit-label" for="descripcion">Desarrolla el incidente</label>
                <textarea asp-for="Descripcion" class="form-control-custom" rows="4" placeholder="Describe detalladamente lo ocurrido"></textarea>
                <span asp-validation-for="Descripcion" class="text-danger"></span>
            </div>

            <div class="unit-item">
                <label class="unit-label" for="evidencia">Sube evidencia del incidente</label>
                <input asp-for="Evidencia" type="file" class="form-control-custom" accept="image/*">
                <span asp-validation-for="Evidencia" class="text-danger"></span>
                <small class="d-block mt-2" style="color:#64748b;">Se requiere que la foto sea clara y se muestre correctamente el incidente</small>
            </div>

            <div class="unit-actions">
                <button type="submit" class="btn-unit btn-primary-unit shadow-sm">Enviar Reporte</button>
                <button type="reset" class="btn-unit btn-secondary-unit">Cancelar</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Toggle Sidebar
            const btn = document.getElementById('btnToggleMenu');
            const sidebar = document.getElementById('sidebarMenu');
            btn.addEventListener('click', () => sidebar.classList.toggle('collapsed'));

            // Lógica Select "Otro"
            const selectIncidente = document.getElementById('Incidente');
            const inputOtro = document.getElementById('otro');
            selectIncidente.addEventListener('change', function () {
                inputOtro.style.display = (this.value === 'otro') ? 'block' : 'none';
                if (this.value !== 'otro') inputOtro.value = '';
            });

            // Aplicar Modo Oscuro desde LocalStorage
            const applyStoredPrefs = () => {
                const isDark = localStorage.getItem('darkMode') === 'true';
                document.body.classList.toggle('dark-mode', isDark);
            };
            applyStoredPrefs();

            selectIncidente.dispatchEvent(new Event('change'));
        });
    </script>
}
