@model IEnumerable<SSMI.Models.RegistroHistoricoModel>

@{
    ViewData["Title"] = "Histórico";
    Layout = "~/Views/Shared/_UsuarioLayout.cshtml";

}

<style>
    /* ... (Mantengo tus estilos originales intactos) ... */
    :root {
        --primary: #1E3C54;
        --accent: #00d4ff;
    }

    .app-viewport {
        height: 100vh;
        background-color: #f0f2f5;
        display: flex;
        align-items: stretch;
        overflow-x: hidden;
        overflow-y: auto; /* Fuerza a que este contenedor sea el encargado de mostrar el scroll vertical */
    }
    }

    #sidebarMenu {
        width: 280px;
        background-color: #1E3C54 !important;
        position: sticky;
        top: 0;
        height: 100vh;
        transition: margin-left 0.3s ease-in-out, visibility 0.3s;
        z-index: 1000;
        flex-shrink: 0;
        overflow-y: auto; /* Si el menú de ayuda o navegación crece en pantallas chicas, tendrá su propio scroll independiente */
    }

        #sidebarMenu.collapsed {
            margin-left: -280px;
            visibility: hidden;
        }

    .nav-btn {
        text-align: left;
        padding: 12px 20px;
        border-radius: 12px !important;
        margin-bottom: 8px;
        transition: 0.3s;
        border: none !important;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 12px;
        color: rgba(255,255,255,0.8);
        background: transparent;
        text-decoration: none;
    }

        .nav-btn.active {
            background: #ffffff !important;
            color: #1E3C54 !important;
        }

    .sticky-header {
        position: sticky;
        top: 0;
        z-index: 999;
        padding: 15px;
    }

    #btnToggleMenu {
        background-color: #1E3C54;
        border: 2px solid #00d4ff;
        color: white;
    }

    .history-content {
        flex-grow: 1;
        padding: 2rem;
    }

    .history-title {
        font-size: 1.8rem;
        font-weight: 800;
        color: var(--primary);
    }

    .filters {
        display: flex;
        gap: 1rem;
        margin: 1.5rem 0;
        flex-wrap: wrap;
    }

    .filter-input {
        padding: 0.7rem 1rem;
        border-radius: 10px;
        border: 1px solid #ddd;
        min-width: 200px;
        background: white;
    }

    .table-card {
        background: white;
        border-radius: 20px;
        padding: 1.5rem;
        box-shadow: 0 8px 25px rgba(0,0,0,0.05);
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        text-align: left;
        padding: 0.75rem;
        color: #6b7280;
        font-size: 0.85rem;
    }

    td {
        padding: 1rem 0.75rem;
        border-top: 1px solid #eee;
        color: #1E3C54;
    }

    .badge {
        padding: 0.4rem 0.8rem;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .ok {
        background: #10b981;
        color: white;
    }

    .pending {
        background: #f59e0b;
        color: white;
    }

    .error {
        background: #ef4444;
        color: white;
    }

    body.dark-mode .app-viewport {
        background-color: #0d1117;
    }

    body.dark-mode .table-card, body.dark-mode .filter-input {
        background: #161b22;
        border-color: #30363d;
        color: #e6edf3;
    }

    body.dark-mode td {
        border-color: #30363d;
        color: #e6edf3;
    }

    body.dark-mode .history-title {
        color: #e6edf3;
    }
</style>

<div class="menu-container d-flex app-viewport">
    <div id="sidebarMenu" class="shadow">
        <div class="d-flex flex-column p-4 h-100">
            <h4 class="text-center mt-2 mb-4" style="color:#00d4ff">SSMI</h4>
            <a asp-controller="Despachador" asp-action="Index" class="nav-btn">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>
            <a asp-controller="Despachador" asp-action="Perfil" class="nav-btn">
                <i class="bi bi-person-circle"></i> Mi Perfil
            </a>
            <a asp-controller="Despachador" asp-action="HistoricoDeRegistros" class="nav-btn active">
                <i class="bi bi-clock-history"></i> Histórico
            </a>
            <div class="mt-auto">
                <a asp-controller="Usuario" asp-action="Ayuda" class="nav-btn">
                    <i class="bi bi-question-circle"></i> Ayuda
                </a>
                <a asp-controller="Usuario" asp-action="AcercaDeNosotros" class="nav-btn"><i class="bi bi-info-square"></i> Acerca de nosotros</a>
            </div>
        </div>
    </div>

    <div class="d-flex flex-column w-100">
        <div class="sticky-header">
            <button id="btnToggleMenu" class="btn rounded-circle shadow-sm">
                <i class="bi bi-list"></i>
            </button>
        </div>

        <div class="history-content">
            <div class="history-title">Histórico de registros</div>
            <form method="get" asp-action="HistoricoDeRegistros" id="formFiltros">
                <div class="filters">
                    <input type="text"
                           name="buscarConductor"
                           class="filter-input"
                           placeholder="Buscar conductor..." />

                    <div class="d-flex align-items-center gap-2">
                        <input type="date"
                               id="inicioFecha"
                               name="inicioFecha"
                               class="filter-input" />

                        <span class="text-muted">al</span>

                        <input type="date"
                               id="finFecha"
                               name="finFecha"
                               class="filter-input"
                               disabled />
                    </div>

                    <select name="buscarEstado" class="filter-input">
                        <option value="">Todos los estados</option>
                        <option value="Aprobado">Aprobado</option>
                        <option value="Pendiente">Pendiente</option>
                        <option value="Rechazado">Rechazado</option>
                    </select>

                    <button type="submit" class="btn btn-primary">
                        Filtrar
                    </button>
                </div>
            </form>

            <div class="table-card">
                <table id="historyTable">
                    <thead>
                        <tr>
                            <th># Económico</th>
                            <th>Conductor</th>
                            <th>Fecha</th>
                            <th>Hora</th>
                            <th>Estado</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr class="history-row">
                                    <td>@item.NumEconomico</td>
                                    <td class="col-conductor" style="font-weight: 600;">@item.Conductor</td>
                                    <td class="col-date">@item.Fecha.ToString("dd/MM/yyyy")</td>
                                    <td>@item.Hora</td>
                                    <td>
                                        @if (item.Estado == "Aprobado")
                                        {
                                            <span class="badge ok col-status">@item.Estado</span>
                                        }
                                        else if (item.Estado == "Pendiente")
                                        {
                                            <span class="badge pending col-status">@item.Estado</span>
                                        }
                                        else
                                        {
                                            <span class="badge error col-status">@item.Estado</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">
                                    <i class="bi bi-info-circle me-2"></i> No se encontraron registros con los filtros aplicados.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const inputInicio = document.getElementById("inicioFecha");
            const inputFin = document.getElementById("finFecha");
            const formFiltros = document.getElementById("formFiltros");

            // 1. Bloquear fechas futuras en ambos calendarios
        const fechaLocal = new Date();
        const anio = fechaLocal.getFullYear();
        const mes = String(fechaLocal.getMonth() + 1).padStart(2, '0');
        const dia = String(fechaLocal.getDate()).padStart(2, '0');
        const hoy = `${anio}-${mes}-${dia}`;

        inputInicio.setAttribute("max", hoy);
        inputFin.setAttribute("max", hoy);

            // 2. Evento cuando cambia el primer calendario
            inputInicio.addEventListener("change", function () {
                if (inputInicio.value) {
                    // Solo habilitamos el segundo, pero NO le ponemos "min" para evitar el mensaje nativo del navegador
                    inputFin.removeAttribute("disabled");
                } else {
                    inputFin.setAttribute("disabled", "true");
                    inputFin.value = "";
                }
                inputInicio.setCustomValidity("");
                inputFin.setCustomValidity("");
            });

            // 3. Validación estricta hecha 100% por nosotros al dar clic en Filtrar
            formFiltros.addEventListener("submit", function (event) {
                inputInicio.setCustomValidity("");
                inputFin.setCustomValidity("");

                if (inputInicio.value && inputFin.value) {
                    const fechaIni = new Date(inputInicio.value + 'T00:00:00');
                    const fechaFin = new Date(inputFin.value + 'T00:00:00');

                    // Si la fecha final es menor o IGUAL a la inicial, lo frenamos con nuestro propio texto
                    if (fechaFin <= fechaIni) {
                        event.preventDefault(); // Detiene el envío

                        // Este es el único mensaje que se va a mostrar en pantalla:
                        inputFin.setCustomValidity("La fecha final debe ser mayor a la fecha inicial.");
                        inputFin.reportValidity();
                    }
                }
            });

            // Limpiar el error cuando el usuario intente corregir la fecha
            inputFin.addEventListener("input", function () {
                inputFin.setCustomValidity("");
            });
        });
    </script>
}