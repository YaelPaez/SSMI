@{
    ViewData["Title"] = "Gestión de Camiones";
    Layout = "~/Views/Shared/_UsuarioLayout.cshtml";
}

<!-- ?? FILTROS SVG DALTONISMO ?? -->
<svg xmlns="http://www.w3.org/2000/svg" width="0" height="0"
     style="position:absolute;pointer-events:none;overflow:hidden;width:0;height:0">
    <defs>
        <filter id="filter-protanopia" color-interpolation-filters="linearRGB">
            <feColorMatrix type="matrix" values="
                0.567 0.433 0     0 0
                0.558 0.442 0     0 0
                0     0.242 0.758 0 0
                0     0     0     1 0" />
        </filter>
        <filter id="filter-deuteranopia" color-interpolation-filters="linearRGB">
            <feColorMatrix type="matrix" values="
                0.625 0.375 0     0 0
                0.7   0.3   0     0 0
                0     0.3   0.7   0 0
                0     0     0     1 0" />
        </filter>
        <filter id="filter-tritanopia" color-interpolation-filters="linearRGB">
            <feColorMatrix type="matrix" values="
                0.95  0.05  0     0 0
                0     0.433 0.567 0 0
                0     0.475 0.525 0 0
                0     0     0     1 0" />
        </filter>
    </defs>
</svg>

<style>
    /* ?? Daltonismo ?? */
    body.protanopia { filter: url(#filter-protanopia) !important; }
    body.deuteranopia { filter: url(#filter-deuteranopia) !important; }
    body.tritanopia { filter: url(#filter-tritanopia) !important; }

    :root { --font-size-base: 1rem; }

    html.font-size-sm, body.font-size-sm { font-size: 0.875rem !important; --font-size-base: 0.875rem; }
    html.font-size-md, body.font-size-md { font-size: 1rem !important; --font-size-base: 1rem; }
    html.font-size-lg, body.font-size-lg { font-size: 1.125rem !important; --font-size-base: 1.125rem; }
    html.font-size-xl, body.font-size-xl { font-size: 1.25rem !important; --font-size-base: 1.25rem; }

    .admin-viewport {
        height: 85vh;
        background-color: #f0f2f5;
        overflow: hidden;
        transition: background-color .3s;
    }

    body.dark-mode .admin-viewport { background-color: #0d1117; }

    .admin-header {
        background: linear-gradient(135deg, #1E3C54, #2a5580);
        color: white;
        padding: 1.5rem;
        box-shadow: 0 4px 15px rgba(30, 60, 84, 0.3);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    body.dark-mode .admin-header {
        background: linear-gradient(135deg, #0d1117, #161b22);
        border-bottom: 2px solid rgba(0, 212, 255, 0.2);
    }

    .admin-header h2 {
        margin: 0;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: calc(var(--font-size-base) * 1.8);
    }

    .admin-nav {
        display: flex;
        gap: 0.5rem;
    }

    .admin-nav a {
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        text-decoration: none;
        color: white;
        background: rgba(255, 255, 255, 0.1);
        transition: all .3s;
        font-weight: 600;
    }

    .admin-nav a:hover {
        background: rgba(255, 255, 255, 0.2);
        transform: translateY(-2px);
    }

    .admin-nav a.active {
        background: #00d4ff;
        color: #1E3C54;
    }

    .admin-content {
        flex-grow: 1;
        overflow-y: auto;
        padding: 1.5rem;
    }

    .section-title {
        color: #1E3C54;
        font-weight: 700;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: calc(var(--font-size-base) * 1.5);
    }

    body.dark-mode .section-title { color: #e6edf3; }

    .badge-status {
        padding: 0.5rem 0.75rem;
        border-radius: 20px;
        font-size: calc(var(--font-size-base) * 0.85);
        font-weight: 600;
        display: inline-block;
    }

    .badge-activo {
        background-color: #d4edda;
        color: #155724;
    }

    .badge-inactivo {
        background-color: #f8d7da;
        color: #721c24;
    }

    .badge-ruta {
        background-color: #d1ecf1;
        color: #0c5460;
    }

    body.dark-mode .badge-activo {
        background-color: rgba(28, 99, 66, 0.3);
        color: #7dde86;
    }

    body.dark-mode .badge-inactivo {
        background-color: rgba(156, 39, 48, 0.3);
        color: #ff8a80;
    }

    body.dark-mode .badge-ruta {
        background-color: rgba(0, 83, 112, 0.3);
        color: #80deea;
    }

    .table {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,.08);
        margin-bottom: 2rem;
    }

    body.dark-mode .table {
        background: #161b22;
        box-shadow: 0 2px 8px rgba(0,0,0,.3);
    }

    .table thead { background-color: #f8f9fa; border-bottom: 2px solid #e9ecef; }
    .table thead th { color: #1E3C54; font-weight: 600; padding: 1rem; font-size: var(--font-size-base); }
    .table tbody td { padding: 1rem; vertical-align: middle; border-bottom: 1px solid #e9ecef; }
    .table tbody tr:hover { background-color: #f8f9fa; }

    body.dark-mode .table thead { background-color: #0d1117; border-color: #30363d; }
    body.dark-mode .table thead th { color: #e6edf3; }
    body.dark-mode .table tbody td { border-color: #30363d; }
    body.dark-mode .table tbody tr:hover { background-color: #0d1117; }

    .btn-admin {
        border: none;
        border-radius: 10px;
        padding: 0.75rem 1.5rem;
        font-weight: 600;
        font-size: var(--font-size-base);
        transition: all .3s;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-agregar {
        background-color: #1E3C54;
        color: white;
    }

    .btn-agregar:hover {
        background-color: #2a5580;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(30, 60, 84, 0.3);
        color: white;
    }

    .btn-editar {
        background-color: #00d4ff;
        color: #1E3C54;
        padding: 0.5rem 1rem;
        font-size: calc(var(--font-size-base) * 0.9);
    }

    .btn-editar:hover {
        background-color: #00bcd4;
        transform: translateY(-1px);
    }

    .btn-eliminar {
        background-color: #eb4d4b;
        color: white;
        padding: 0.5rem 1rem;
        font-size: calc(var(--font-size-base) * 0.9);
    }

    .btn-eliminar:hover {
        background-color: #d63031;
        transform: translateY(-1px);
    }

    .action-cell {
        display: flex;
        gap: 0.5rem;
    }

    @@media (max-width: 768px) {
        .admin-header {
            flex-direction: column;
            gap: 1rem;
        }

        .admin-nav {
            flex-wrap: wrap;
        }

        .admin-content {
            padding: 1rem;
        }

        .table {
            font-size: calc(var(--font-size-base) * 0.9);
        }

        .table thead th,
        .table tbody td {
            padding: 0.75rem;
        }
    }
</style>

<div class="d-flex flex-column admin-viewport">
    <!-- ?? HEADER ?? -->
    <div class="admin-header">
        <h2>
            <i class="bi bi-bus-front"></i> Gestión de Camiones
        </h2>
        <div class="admin-nav">
            <a asp-action="Paradas">Paradas</a>
            <a asp-action="Camiones" class="active">Camiones</a>
            <a asp-action="Conductores">Conductores</a>
            <a asp-action="Monitoreo">Monitoreo</a>
        </div>
    </div>

    <!-- ?? CONTENIDO ?? -->
    <div class="admin-content">
        <div class="mb-3">
            <button class="btn btn-admin btn-agregar" data-bs-toggle="modal" data-bs-target="#modalCamion">
                <i class="bi bi-plus-circle"></i> Nuevo Camión
            </button>
        </div>

        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Placa</th>
                        <th>Conductor</th>
                        <th>Capacidad</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>ABC-123</td>
                        <td>Juan Pérez</td>
                        <td>45 pasajeros</td>
                        <td><span class="badge-status badge-activo">Activo</span></td>
                        <td>
                            <div class="action-cell">
                                <button class="btn btn-admin btn-editar"><i class="bi bi-pencil"></i></button>
                                <button class="btn btn-admin btn-eliminar"><i class="bi bi-trash"></i></button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td>XYZ-456</td>
                        <td>María López</td>
                        <td>50 pasajeros</td>
                        <td><span class="badge-status badge-ruta">En Ruta</span></td>
                        <td>
                            <div class="action-cell">
                                <button class="btn btn-admin btn-editar"><i class="bi bi-pencil"></i></button>
                                <button class="btn btn-admin btn-eliminar"><i class="bi bi-trash"></i></button>
                            </div>
                        </td>
                    </tr>
                    <tr>
                        <td>DEF-789</td>
                        <td>—</td>
                        <td>48 pasajeros</td>
                        <td><span class="badge-status badge-inactivo">Inactivo</span></td>
                        <td>
                            <div class="action-cell">
                                <button class="btn btn-admin btn-editar"><i class="bi bi-pencil"></i></button>
                                <button class="btn btn-admin btn-eliminar"><i class="bi bi-trash"></i></button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- ?? MODAL AGREGAR CAMIÓN ?? -->
<div class="modal fade" id="modalCamion" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-bus-front"></i> Agregar Camión</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form>
                    <div class="mb-3">
                        <label class="form-label">Placa</label>
                        <input type="text" class="form-control" placeholder="ABC-123">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Capacidad</label>
                        <input type="number" class="form-control" placeholder="45">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Conductor</label>
                        <select class="form-control">
                            <option>Seleccionar conductor</option>
                            <option>Juan Pérez</option>
                            <option>María López</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-admin btn-agregar">Guardar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function applyStoredPrefs() {
            var dal = localStorage.getItem('daltonismMode') || 'normal';
            document.body.classList.remove('protanopia', 'deuteranopia', 'tritanopia');
            document.documentElement.classList.remove('protanopia', 'deuteranopia', 'tritanopia');
            if (dal !== 'normal') {
                document.body.classList.add(dal);
                document.documentElement.classList.add(dal);
            }

            var isDark = localStorage.getItem('darkMode') === 'true';
            document.body.classList.toggle('dark-mode', isDark);

            var fs  = localStorage.getItem('fontSize') || 'md';
            var map = { sm: '0.875rem', md: '1rem', lg: '1.125rem', xl: '1.25rem' };
            var sz  = map[fs] || '1rem';
            document.documentElement.style.setProperty('--font-size-base', sz);
            document.documentElement.style.fontSize = sz;
            document.body.style.fontSize = sz;
            ['font-size-sm','font-size-md','font-size-lg','font-size-xl'].forEach(function(c){
                document.documentElement.classList.remove(c);
                document.body.classList.remove(c);
            });
            document.documentElement.classList.add('font-size-' + fs);
            document.body.classList.add('font-size-' + fs);
        })();
    </script>
}
