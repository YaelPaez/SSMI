                                        <button class="btn btn-admin btn-editar"><i class="bi bi-pencil"></i></button>
                                        <button class="btn btn-admin btn-eliminar"><i class="bi bi-trash"></i></button>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td>XYZ-456</td>
                                <td>María López</td>
                                <td>50 pasajeros</td>
                                <td><span class="badge-status badge-ruta">En Ruta</span></td>
                                <td>
                                    <div class="action-cell">
                                        <button class="btn btn-admin btn-editar"><i class="bi bi-pencil"></i></button>
                                        <button class="btn btn-admin btn-eliminar"><i class="bi bi-trash"></i></button>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td>DEF-789</td>
                                <td>—</td>
                                <td>48 pasajeros</td>
                                <td><span class="badge-status badge-inactivo">Inactivo</span></td>
                                <td>
                                    <div class="action-cell">
                                        <button class="btn btn-admin btn-editar"><i class="bi bi-pencil"></i></button>
                                        <button class="btn btn-admin btn-eliminar"><i class="bi bi-trash"></i></button>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- ══ SECCIÓN: CONDUCTORES ══ -->
            <div id="conductores" class="seccion">
                <h3>
                    <i class="bi bi-person-badge"></i> Gestión de Conductores
                </h3>

                <button class="btn btn-admin btn-agregar mb-3" data-bs-toggle="modal" data-bs-target="#modalConductor">
                    <i class="bi bi-plus-circle"></i> Nuevo Conductor
                </button>

                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Nombre</th>
                                <th>Licencia</th>
                                <th>Camión Asignado</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Juan Pérez</td>
                                <td>LIC-001</td>
                                <td>ABC-123</td>
                                <td><span class="badge-status badge-activo">Activo</span></td>
                                <td>
                                    <div class="action-cell">
                                        <button class="btn btn-admin btn-editar"><i class="bi bi-pencil"></i></button>
                                        <button class="btn btn-admin btn-eliminar"><i class="bi bi-trash"></i></button>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td>María López</td>
                                <td>LIC-002</td>
                                <td>XYZ-456</td>
                                <td><span class="badge-status badge-activo">Activo</span></td>
                                <td>
                                    <div class="action-cell">
                                        <button class="btn btn-admin btn-editar"><i class="bi bi-pencil"></i></button>
                                        <button class="btn btn-admin btn-eliminar"><i class="bi bi-trash"></i></button>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td>Carlos Rodríguez</td>
                                <td>LIC-003</td>
                                <td>—</td>
                                <td><span class="badge-status badge-inactivo">Disponible</span></td>
                                <td>
                                    <div class="action-cell">
                                        <button class="btn btn-admin btn-editar"><i class="bi bi-pencil"></i></button>
                                        <button class="btn btn-admin btn-eliminar"><i class="bi bi-trash"></i></button>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- ══ SECCIÓN: MONITOREO ══ -->
            <div id="monitoreo" class="seccion">
                <h3>
                    <i class="bi bi-activity"></i> Monitoreo en Tiempo Real
                </h3>

                <div class="map-container">
                    <div class="map-placeholder">
                        <i class="bi bi-map"></i>
                        <p>Mapa integrado (SignalR Ready)</p>
                        <small>Placeholder para integración con Google Maps o Leaflet</small>
                    </div>
                </div>

                <div class="form-admin mt-4">
                    <h5 class="mb-3">
                        <i class="bi bi-speedometer2"></i> Estado de Camiones en Línea
                    </h5>
                    <div class="table-responsive">
                        <table class="table">
