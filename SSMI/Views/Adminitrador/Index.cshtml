@{
    ViewData["Title"] = "Administración de Rutas";
    Layout = "~/Views/Shared/_UsuarioLayout.cshtml";

    // Unificamos el nombre de la acción (si usas ConductoresEdit, cámbialo aquí también)
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}


<style>
    /* ── Daltonismo ── */
    body.protanopia {
        filter: url(#filter-protanopia) !important;
    }

    body.deuteranopia {
        filter: url(#filter-deuteranopia) !important;
    }

    body.tritanopia {
        filter: url(#filter-tritanopia) !important;
    }

    /* ── Tamaños de fuente globales mediante HTML ── */
    html {
        font-size: 1rem;
    }

        html.font-size-sm {
            font-size: 0.875rem !important;
        }

        html.font-size-md {
            font-size: 1rem !important;
        }

        html.font-size-lg {
            font-size: 1.125rem !important;
        }

        html.font-size-xl {
            font-size: 1.25rem !important;
        }

    /* ── Layout ── */
    .app-viewport {
        height: 85vh;
        background-color: #f0f2f5;
        overflow: hidden;
        transition: background-color .3s;
    }

    /* ── Sidebar ── */
    #sidebarMenu {
        width: 280px;
        background-color: #1E3C54 !important;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        z-index: 1000;
        flex-shrink: 0;
    }

        #sidebarMenu h4 {
            color: #00d4ff;
            font-weight: 800;
            letter-spacing: 1px;
        }

    .nav-btn {
        text-align: left;
        padding: 12px 20px;
        border-radius: 12px !important;
        margin-bottom: 8px;
        transition: 0.3s;
        border: none !important;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 12px;
        color: rgba(255,255,255,0.8);
        background: transparent;
        text-decoration: none;
        cursor: pointer;
        font-size: 1rem;
    }

        .nav-btn:hover {
            background: rgba(255,255,255,.1);
            color: #fff;
            transform: translateX(5px);
        }

        .nav-btn.active {
            background: #fff !important;
            color: #1E3C54 !important;
            box-shadow: 0 4px 15px rgba(0,0,0,.2);
        }

    /* ── Modo oscuro — sidebar ── */
    body.dark-mode .app-viewport {
        background-color: #0d1117;
    }

    body.dark-mode #sidebarMenu {
        background-color: #0d1117 !important;
        border-right: 1px solid rgba(0,212,255,.12);
    }

    body.dark-mode .nav-btn {
        color: rgba(200,220,240,.7);
    }

        body.dark-mode .nav-btn:hover {
            background: rgba(0,212,255,.08);
            color: #e6edf3;
        }

        body.dark-mode .nav-btn.active {
            background: rgba(0,212,255,.15) !important;
            color: #00d4ff !important;
            box-shadow: none;
        }

    /* ── Botón toggle ── */
    #btnToggleMenu {
        background-color: #1E3C54;
        border: 2px solid #00d4ff;
        color: white;
        width: 44px;
        height: 44px;
        transition: .3s;
    }

        #btnToggleMenu:hover {
            transform: scale(1.08);
            box-shadow: 0 0 12px rgba(0,212,255,.35);
        }

    body.dark-mode #btnToggleMenu {
        background-color: #0d1117;
    }

    /* ── Área de contenido ── */
    .admin-content {
        flex-grow: 1;
        overflow-y: auto;
        padding: 1.5rem;
        transition: background .3s;
    }

    /* ── Secciones ── */
    .seccion {
        display: none;
        animation: fadeIn 0.3s ease-in;
    }

        .seccion.active {
            display: block;
        }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .seccion h3 {
        color: #1E3C54;
        font-weight: 700;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: 1.5rem;
    }

    body.dark-mode .seccion h3 {
        color: #e6edf3;
    }

    /* ── Formularios / Tarjetas ── */
    .form-admin {
        background: white;
        border-radius: 12px;
        padding: 2rem;
        box-shadow: 0 2px 8px rgba(0,0,0,.08);
        margin-bottom: 2rem;
        transition: background .3s;
    }

    body.dark-mode .form-admin {
        background: #161b22;
        box-shadow: 0 2px 8px rgba(0,0,0,.3);
    }

    /* ── Responsive ── */
    @@media (max-width: 768px) {
        #sidebarMenu {
            position: absolute;
            left: 0;
            top: 0;
            height: 100%;
            margin-left: -280px;
        }

        .admin-content {
            padding: 1rem;
        }
    }
</style>

<div class="d-flex app-viewport">
    <div id="sidebarMenu" class="shadow">
        <div class="d-flex flex-column p-4 h-100">
            <h4 class="text-center mt-2 mb-4">SSMI Admin</h4>

            <a asp-controller="Adminitrador" asp-action="Paradas" class="nav-btn @(currentAction == "Paradas" ? "active" : "")">
                <i class="bi bi-geo-alt"></i> Paradas
            </a>

            <a asp-controller="Adminitrador" asp-action="Camiones" class="nav-btn @(currentAction == "Camiones" ? "active" : "")">
                <i class="bi bi-bus-front"></i> Camiones
            </a>

            <a asp-controller="Adminitrador" asp-action="Conductores" class="nav-btn @(currentAction == "Conductores" ? "active" : "")">
                <i class="bi bi-person-badge"></i> Conductores
            </a>

            <a asp-controller="Adminitrador" asp-action="Monitoreo" class="nav-btn @(currentAction == "Monitoreo" ? "active" : "")">
                <i class="bi bi-activity"></i> Monitoreo
            </a>



            <div class="mt-auto">
                <a asp-controller="Login" asp-action="CerrarSesion" class="nav-btn"><i class="bi bi-box-arrow-left"></i> Salir</a>
            </div>
        </div>
    </div>

    <div class="flex-grow-1 d-flex flex-column">
        <div class="p-3 d-flex align-items-center gap-3 border-bottom">
            <button id="btnToggleMenu" class="btn btn-dark rounded-circle shadow-sm">
                <i class="bi bi-list"></i>
            </button>
            <h2 class="mb-0">Administración</h2>
        </div>

        <div class="admin-content">
            <h3 class="mb-3"><i class="bi bi-grid"></i> Panel de administración</h3>
            <p class="text-muted mb-4">Selecciona una opción del menú para administrar paradas, camiones, conductores o monitoreo.</p>

            <div class="row g-3">
                <div class="col-12 col-md-6 col-lg-3">
                    <a asp-controller="Adminitrador" asp-action="Paradas" class="text-decoration-none">
                        <div class="form-admin" style="cursor:pointer;">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-geo-alt fs-4"></i>
                                <strong>Paradas</strong>
                            </div>
                            <div class="text-muted mt-2">Gestionar paradas y orden de ruta.</div>
                        </div>
                    </a>
                </div>
                <div class="col-12 col-md-6 col-lg-3">
                    <a asp-controller="Adminitrador" asp-action="Camiones" class="text-decoration-none">
                        <div class="form-admin" style="cursor:pointer;">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-bus-front fs-4"></i>
                                <strong>Camiones</strong>
                            </div>
                            <div class="text-muted mt-2">Alta, baja y edición de camiones.</div>
                        </div>
                    </a>
                </div>
                <div class="col-12 col-md-6 col-lg-3">
                    <a asp-controller="Adminitrador" asp-action="Conductores" class="text-decoration-none">
                        <div class="form-admin" style="cursor:pointer;">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-person-badge fs-4"></i>
                                <strong>Conductores</strong>
                            </div>
                            <div class="text-muted mt-2">Gestión de conductores y asignaciones.</div>
                        </div>
                    </a>
                </div>
                <div class="col-12 col-md-6 col-lg-3">
                    <a asp-controller="Adminitrador" asp-action="Monitoreo" class="text-decoration-none">
                        <div class="form-admin" style="cursor:pointer;">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-activity fs-4"></i>
                                <strong>Monitoreo</strong>
                            </div>
                            <div class="text-muted mt-2">Vista en tiempo real del sistema.</div>
                        </div>
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const btn = document.getElementById('btnToggleMenu');
            const sidebar = document.getElementById('sidebarMenu');

            btn?.addEventListener('click', function () {
                sidebar.style.marginLeft = sidebar.style.marginLeft === '-280px' ? '0px' : '-280px';
                btn.classList.toggle('active');
            });
        });
    </script>
}