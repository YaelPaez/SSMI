@{
    ViewData["Title"] = "Administración de Rutas";
    Layout = "~/Views/Shared/_UsuarioLayout.cshtml";
}

<!-- ══ FILTROS SVG DALTONISMO ══ -->
<svg xmlns="http://www.w3.org/2000/svg" width="0" height="0"
     style="position:absolute;pointer-events:none;overflow:hidden;width:0;height:0">
    <defs>
        <filter id="filter-protanopia" color-interpolation-filters="linearRGB">
            <feColorMatrix type="matrix" values="
                0.567 0.433 0     0 0
                0.558 0.442 0     0 0
                0     0.242 0.758 0 0
                0     0     0     1 0" />
        </filter>
        <filter id="filter-deuteranopia" color-interpolation-filters="linearRGB">
            <feColorMatrix type="matrix" values="
                0.625 0.375 0     0 0
                0.7   0.3   0     0 0
                0     0.3   0.7   0 0
                0     0     0     1 0" />
        </filter>
        <filter id="filter-tritanopia" color-interpolation-filters="linearRGB">
            <feColorMatrix type="matrix" values="
                0.95  0.05  0     0 0
                0     0.433 0.567 0 0
                0     0.475 0.525 0 0
                0     0     0     1 0" />
        </filter>
    </defs>
</svg>

<style>
    /* ── Daltonismo ── */
    body.protanopia {
        filter: url(#filter-protanopia) !important;
    }

    body.deuteranopia {
        filter: url(#filter-deuteranopia) !important;
    }

    body.tritanopia {
        filter: url(#filter-tritanopia) !important;
    }

    /* ── Variables ── */
    :root {
        --font-size-base: 1rem;
    }

    /* ── Tamaños de fuente ── */
    html.font-size-sm, body.font-size-sm {
        font-size: 0.875rem !important;
        --font-size-base: 0.875rem;
    }

    html.font-size-md, body.font-size-md {
        font-size: 1rem !important;
        --font-size-base: 1rem;
    }

    html.font-size-lg, body.font-size-lg {
        font-size: 1.125rem !important;
        --font-size-base: 1.125rem;
    }

    html.font-size-xl, body.font-size-xl {
        font-size: 1.25rem !important;
        --font-size-base: 1.25rem;
    }

    /* ── Layout ── */
    .app-viewport {
        height: 85vh;
        background-color: #f0f2f5;
        overflow: hidden;
        transition: background-color .3s;
    }

    /* ── Sidebar ── */
    #sidebarMenu {
        width: 280px;
        background-color: #1E3C54 !important;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        z-index: 1000;
        flex-shrink: 0;
    }

        #sidebarMenu h4 {
            color: #00d4ff;
            font-weight: 800;
            letter-spacing: 1px;
        }

    .nav-btn {
        text-align: left;
        padding: 12px 20px;
        border-radius: 12px !important;
        margin-bottom: 8px;
        transition: 0.3s;
        border: none !important;
        font-weight: 500;
        display: flex;
        align-items: center;
        gap: 12px;
        color: rgba(255,255,255,0.8);
        background: transparent;
        text-decoration: none;
        cursor: pointer;
        font-size: var(--font-size-base, 1rem);
    }

        .nav-btn:hover {
            background: rgba(255,255,255,.1);
            color: #fff;
            transform: translateX(5px);
        }

        .nav-btn.active {
            background: #fff !important;
            color: #1E3C54 !important;
            box-shadow: 0 4px 15px rgba(0,0,0,.2);
        }

    /* ── Modo oscuro — sidebar ── */
    body.dark-mode .app-viewport {
        background-color: #0d1117;
    }

    body.dark-mode #sidebarMenu {
        background-color: #0d1117 !important;
        border-right: 1px solid rgba(0,212,255,.12);
    }

    body.dark-mode .nav-btn {
        color: rgba(200,220,240,.7);
    }

        body.dark-mode .nav-btn:hover {
            background: rgba(0,212,255,.08);
            color: #e6edf3;
        }

        body.dark-mode .nav-btn.active {
            background: rgba(0,212,255,.15) !important;
            color: #00d4ff !important;
            box-shadow: none;
        }

    /* ── Botón toggle ── */
    #btnToggleMenu {
        background-color: #1E3C54;
        border: 2px solid #00d4ff;
        color: white;
        width: 44px;
        height: 44px;
        transition: .3s;
    }

        #btnToggleMenu:hover {
            transform: scale(1.08);
            box-shadow: 0 0 12px rgba(0,212,255,.35);
        }

    body.dark-mode #btnToggleMenu {
        background-color: #0d1117;
    }

    /* ── Área de contenido ── */
    .admin-content {
        flex-grow: 1;
        overflow-y: auto;
        padding: 1.5rem;
        transition: background .3s;
    }

    /* ── Secciones ── */
    .seccion {
        display: none;
        animation: fadeIn 0.3s ease-in;
    }

        .seccion.active {
            display: block;
        }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* ── Título de sección ── */
    .seccion h3 {
        color: #1E3C54;
        font-weight: 700;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: calc(var(--font-size-base) * 1.5);
    }

    body.dark-mode .seccion h3 {
        color: #e6edf3;
    }

    /* ── Tablas ── */
    .table {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,.08);
        margin-bottom: 2rem;
        transition: background .3s, box-shadow .3s;
    }

        .table thead {
            background-color: #f8f9fa;
            border-bottom: 2px solid #e9ecef;
        }

            .table thead th {
                color: #1E3C54;
                font-weight: 600;
                padding: 1rem;
                font-size: var(--font-size-base);
            }

        .table tbody td {
            padding: 1rem;
            vertical-align: middle;
            border-bottom: 1px solid #e9ecef;
        }

        .table tbody tr:hover {
            background-color: #f8f9fa;
            transition: background-color .2s;
        }

    body.dark-mode .table {
        background: #161b22;
        box-shadow: 0 2px 8px rgba(0,0,0,.3);
    }

        body.dark-mode .table thead {
            background-color: #0d1117;
            border-color: #30363d;
        }

            body.dark-mode .table thead th {
                color: #e6edf3;
            }

        body.dark-mode .table tbody td {
            border-color: #30363d;
        }

        body.dark-mode .table tbody tr:hover {
            background-color: #0d1117;
        }

    /* ── Etiquetas de estado ── */
    .badge-status {
        padding: 0.5rem 0.75rem;
        border-radius: 20px;
        font-size: calc(var(--font-size-base) * 0.85);
        font-weight: 600;
        display: inline-block;
    }

    .badge-activo {
        background-color: #d4edda;
        color: #155724;
    }

    .badge-inactivo {
        background-color: #f8d7da;
        color: #721c24;
    }

    .badge-ruta {
        background-color: #d1ecf1;
        color: #0c5460;
    }

    body.dark-mode .badge-activo {
        background-color: rgba(28, 99, 66, 0.3);
        color: #7dde86;
    }

    body.dark-mode .badge-inactivo {
        background-color: rgba(156, 39, 48, 0.3);
        color: #ff8a80;
    }

    body.dark-mode .badge-ruta {
        background-color: rgba(0, 83, 112, 0.3);
        color: #80deea;
    }

    /* ── Botones ── */
    .btn-admin {
        border: none;
        border-radius: 10px;
        padding: 0.75rem 1.5rem;
        font-weight: 600;
        font-size: var(--font-size-base);
        transition: all .3s;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .btn-agregar {
        background-color: #1E3C54;
        color: white;
    }

        .btn-agregar:hover {
            background-color: #2a5580;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(30, 60, 84, 0.3);
            color: white;
        }

    .btn-editar {
        background-color: #00d4ff;
        color: #1E3C54;
        padding: 0.5rem 1rem;
        font-size: calc(var(--font-size-base) * 0.9);
    }

        .btn-editar:hover {
            background-color: #00bcd4;
            transform: translateY(-1px);
        }

    .btn-eliminar {
        background-color: #eb4d4b;
        color: white;
        padding: 0.5rem 1rem;
        font-size: calc(var(--font-size-base) * 0.9);
    }

        .btn-eliminar:hover {
            background-color: #d63031;
            transform: translateY(-1px);
        }

    body.dark-mode .btn-agregar {
        background-color: rgba(0, 212, 255, 0.2);
        color: #00d4ff;
        border: 1px solid rgba(0, 212, 255, 0.4);
    }

        body.dark-mode .btn-agregar:hover {
            background-color: rgba(0, 212, 255, 0.3);
            box-shadow: 0 4px 12px rgba(0, 212, 255, 0.2);
        }

    /* ── Monitoreo (Mapa) ── */
    .map-container {
        width: 100%;
        height: 500px;
        background: linear-gradient(135deg, #e5e3df, #f5f3f0);
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #8b949e;
        font-size: calc(var(--font-size-base) * 1.1);
        box-shadow: 0 4px 15px rgba(0,0,0,.1);
        overflow: hidden;
        position: relative;
    }

    body.dark-mode .map-container {
        background: linear-gradient(135deg, #161b22, #0d1117);
        box-shadow: 0 4px 15px rgba(0,0,0,.3);
    }

    .map-placeholder {
        text-align: center;
    }

        .map-placeholder i {
            font-size: 3rem;
            margin-bottom: 1rem;
            opacity: 0.5;
        }

    /* ── Formularios ── */
    .form-admin {
        background: white;
        border-radius: 12px;
        padding: 2rem;
        box-shadow: 0 2px 8px rgba(0,0,0,.08);
        margin-bottom: 2rem;
        transition: background .3s;
    }

    body.dark-mode .form-admin {
        background: #161b22;
        box-shadow: 0 2px 8px rgba(0,0,0,.3);
    }

    .form-admin .form-label {
        color: #1E3C54;
        font-weight: 600;
        margin-bottom: 0.5rem;
        font-size: var(--font-size-base);
    }

    body.dark-mode .form-admin .form-label {
        color: #e6edf3;
    }

    .form-admin .form-control {
        border-radius: 8px;
        border: 1px solid #e9ecef;
        padding: 0.75rem 1rem;
        font-size: var(--font-size-base);
        transition: border-color .3s, box-shadow .3s;
    }

        .form-admin .form-control:focus {
            border-color: #00d4ff;
            box-shadow: 0 0 0 3px rgba(0, 212, 255, 0.1);
        }

    body.dark-mode .form-admin .form-control {
        background: #0d1117;
        border-color: #30363d;
        color: #e6edf3;
    }

        body.dark-mode .form-admin .form-control:focus {
            background: #0d1117;
        }

    /* ── Grid de acciones ── */
    .action-cell {
        display: flex;
        gap: 0.5rem;
    }

    /* ── Responsive ── */
    @@media (max-width: 768px) {
        #sidebarMenu {
            position: absolute;
            left: 0;
            top: 0;
            height: 100%;
            margin-left: -280px;
        }

        .admin-content {
            padding: 1rem;
        }

        .table {
            font-size: calc(var(--font-size-base) * 0.9);
        }

            .table thead th,
            .table tbody td {
                padding: 0.75rem;
            }
    }
</style>

<div class="d-flex app-viewport">
    <!-- ══ SIDEBAR ADMIN ══ -->
    <div id="sidebarMenu" class="shadow">
        <div class="d-flex flex-column p-4 h-100">
            <h4 class="text-center mt-2 mb-4">SSMI Admin</h4>
            
            <button class="nav-btn active" onclick="mostrarSeccion('paradas')">
                <i class="bi bi-geo-alt"></i> Paradas
            </button>

            <button class="nav-btn" onclick="mostrarSeccion('camiones')">
                <i class="bi bi-bus-front"></i> Camiones
            </button>

            <button class="nav-btn" onclick="mostrarSeccion('conductoresIndex')">
                <i class="bi bi-person-badge"></i> Conductores
            </button>

            <button class="nav-btn" onclick="mostrarSeccion('monitoreo')">
                <i class="bi bi-activity"></i> Monitoreo
            </button>

            <div class="mt-auto">
                <a href="/" class="nav-btn"><i class="bi bi-box-arrow-left"></i> Salir</a>
            </div>
        </div>
    </div>

    <!-- ══ CONTENIDO PRINCIPAL ══ -->
    <div class="flex-grow-1 d-flex flex-column">
        <div class="p-3 d-flex align-items-center gap-3 border-bottom">
            <button id="btnToggleMenu" class="btn btn-dark rounded-circle shadow-sm" style="width: 45px; height: 45px;">
                <i class="bi bi-list"></i>
            </button>
            <h2 class="mb-0">Administración de Rutas</h2>
        </div>

        <div class="admin-content">
            <!-- ══ SECCIÓN: PARADAS ══ -->
            <div id="paradas" class="seccion active">
                <h3>
                    <i class="bi bi-geo-alt"></i> Gestión de Paradas
                </h3>

                <button class="btn btn-admin btn-agregar mb-3" data-bs-toggle="modal" data-bs-target="#modalParada">
                    <i class="bi bi-plus-circle"></i> Agregar Parada
                </button>

                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Nombre</th>
                                <th>Latitud</th>
                                <th>Longitud</th>
                                <th>Orden</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Parada Central</td>
                                <td>19.4326</td>
                                <td>-99.1332</td>
                                <td>1</td>
                                <td>
                                    <div class="action-cell">
                                        <button class="btn btn-admin btn-editar"><i class="bi bi-pencil"></i></button>
                                        <button class="btn btn-admin btn-eliminar"><i class="bi bi-trash"></i></button>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td>Parada Secundaria</td>
                                <td>19.4350</td>
                                <td>-99.1350</td>
                                <td>2</td>
                                <td>
                                    <div class="action-cell">
                                        <button class="btn btn-admin btn-editar"><i class="bi bi-pencil"></i></button>
                                        <button class="btn btn-admin btn-eliminar"><i class="bi bi-trash"></i></button>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- ══ SECCIÓN: CAMIONES ══ -->
            <div id="camiones" class="seccion">
                <h3>
                    <i class="bi bi-bus-front"></i> Gestión de Camiones
                </h3>

                <button class="btn btn-admin btn-agregar mb-3" data-bs-toggle="modal" data-bs-target="#modalCamion">
                    <i class="bi bi-plus-circle"></i> Nuevo Camión
                </button>

                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Placa</th>
                                <th>Conductor</th>
