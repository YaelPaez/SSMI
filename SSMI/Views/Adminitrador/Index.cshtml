@section Scripts {
    <script>
        /* ── Alternar entre secciones ── */
        function mostrarSeccion(seccionId) {
            // Ocultar todas las secciones
            const secciones = document.querySelectorAll('.seccion');
            secciones.forEach(s => s.classList.remove('active'));

            // Remover clase active de todos los botones
            const botones = document.querySelectorAll('.nav-btn');
            botones.forEach(b => b.classList.remove('active'));

            // Mostrar sección seleccionada
            const seccionActual = document.getElementById(seccionId);
            if (seccionActual) {
                seccionActual.classList.add('active');
            }

            // Marcar botón como activo
            event.target.closest('.nav-btn')?.classList.add('active');
        }

        /* ── Toggle del sidebar ── */
        document.addEventListener("DOMContentLoaded", function () {
            const btn = document.getElementById('btnToggleMenu');
            const sidebar = document.getElementById('sidebarMenu');

            btn.addEventListener('click', function () {
                sidebar.style.marginLeft = sidebar.style.marginLeft === '-280px' ? '0px' : '-280px';
                btn.classList.toggle('active');
            });
        });

        /* ── Aplicar preferencias guardadas ── */
        (function applyStoredPrefs() {
            var dal = localStorage.getItem('daltonismMode') || 'normal';
            document.body.classList.remove('protanopia', 'deuteranopia', 'tritanopia');
            document.documentElement.classList.remove('protanopia', 'deuteranopia', 'tritanopia');
            if (dal !== 'normal') {
                document.body.classList.add(dal);
                document.documentElement.classList.add(dal);
            }

            var isDark = localStorage.getItem('darkMode') === 'true';
            document.body.classList.toggle('dark-mode', isDark);

            var fs  = localStorage.getItem('fontSize') || 'md';
            var map = { sm: '0.875rem', md: '1rem', lg: '1.125rem', xl: '1.25rem' };
            var sz  = map[fs] || '1rem';
            document.documentElement.style.setProperty('--font-size-base', sz);
            document.documentElement.style.fontSize = sz;
            document.body.style.fontSize = sz;
            ['font-size-sm','font-size-md','font-size-lg','font-size-xl'].forEach(function(c){
                document.documentElement.classList.remove(c);
                document.body.classList.remove(c);
            });
            document.documentElement.classList.add('font-size-' + fs);
            document.body.classList.add('font-size-' + fs);
        })();
    </script>
}
