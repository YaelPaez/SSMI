@{
    ViewData["Title"] = "Monitoreo en Tiempo Real";
    Layout = "~/Views/Shared/_UsuarioLayout.cshtml";
}

<style>
    /* ── Área principal ── */
    .area-admin {
        height: 85vh;
        background-color: #f0f2f5;
        overflow: hidden;
        transition: background-color .3s;
    }

    body.dark-mode .area-admin {
        background-color: #0d1117;
    }

    /* ── Encabezado ── */
    .encabezado-admin {
        background: linear-gradient(135deg, #1E3C54, #2a5580);
        color: white;
        padding: 1.5rem;
        box-shadow: 0 4px 15px rgba(30, 60, 84, 0.3);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    body.dark-mode .encabezado-admin {
        background: linear-gradient(135deg, #0d1117, #161b22);
        border-bottom: 2px solid rgba(0, 212, 255, 0.2);
    }

    .encabezado-admin h2 {
        margin: 0;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: calc(var(--font-size-base) * 1.8);
    }

    /* ── Navegación ── */
    .navegacion-admin {
        display: flex;
        gap: 0.5rem;
    }

        .navegacion-admin a {
            padding: 0.75rem 1.5rem;
            border-radius: 8px;
            text-decoration: none;
            color: white;
            background: rgba(255, 255, 255, 0.1);
            transition: all .3s;
            font-weight: 600;
        }

            .navegacion-admin a:hover {
                background: rgba(255, 255, 255, 0.2);
                transform: translateY(-2px);
            }

            .navegacion-admin a.active {
                background: #00d4ff;
                color: #1E3C54;
            }

    /* ── Contenido ── */
    .contenido-admin {
        flex-grow: 1;
        overflow-y: auto;
        padding: 1.5rem;
    }

    .titulo-seccion {
        color: #1E3C54;
        font-weight: 700;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: calc(var(--font-size-base) * 1.5);
    }

    body.dark-mode .titulo-seccion {
        color: #e6edf3;
    }

    /* ── Insignias de estado ── */
    .insignia-estado {
        padding: 0.5rem 0.75rem;
        border-radius: 20px;
        font-size: calc(var(--font-size-base) * 0.85);
        font-weight: 600;
        display: inline-block;
    }

    .insignia-ruta {
        background-color: #d1ecf1;
        color: #0c5460;
    }

    body.dark-mode .insignia-ruta {
        background-color: rgba(0, 83, 112, 0.3);
        color: #80deea;
    }

    /* ── Contenedor del mapa ── */
    .contenedor-mapa {
        width: 100%;
        height: 400px;
        background: linear-gradient(135deg, #e5e3df, #f5f3f0);
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #8b949e;
        font-size: calc(var(--font-size-base) * 1.1);
        box-shadow: 0 4px 15px rgba(0,0,0,.1);
        overflow: hidden;
        position: relative;
        margin-bottom: 2rem;
    }

    body.dark-mode .contenedor-mapa {
        background: linear-gradient(135deg, #161b22, #0d1117);
        box-shadow: 0 4px 15px rgba(0,0,0,.3);
    }

    .marcador-mapa {
        text-align: center;
    }

        .marcador-mapa i {
            font-size: 3rem;
            margin-bottom: 1rem;
            opacity: 0.5;
        }

    /* ── Tabla ── */
    .table {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,.08);
        margin-bottom: 2rem;
    }

    body.dark-mode .table {
        background: #161b22;
        box-shadow: 0 2px 8px rgba(0,0,0,.3);
    }

    .table thead {
        background-color: #f8f9fa;
        border-bottom: 2px solid #e9ecef;
    }

        .table thead th {
            color: #1E3C54;
            font-weight: 600;
            padding: 1rem;
            font-size: var(--font-size-base);
        }

    .table tbody td {
        padding: 1rem;
        vertical-align: middle;
        border-bottom: 1px solid #e9ecef;
        color: #1E3C54;
    }

    .table tbody tr:hover {
        background-color: #f8f9fa;
    }

    body.dark-mode .table thead {
        background-color: #0d1117;
        border-color: #30363d;
    }

        body.dark-mode .table thead th {
            color: #e6edf3;
        }

    body.dark-mode .table tbody td {
        border-color: #30363d;
        color: #e6edf3;
    }

    body.dark-mode .table tbody tr:hover {
        background-color: #0d1117;
    }

    /* ── Responsive ── */
    @@media (max-width: 768px) {
        .encabezado-admin {
            flex-direction: column;
            gap: 1rem;
        }

        .navegacion-admin {
            flex-wrap: wrap;
        }

        .contenido-admin {
            padding: 1rem;
        }

        .contenedor-mapa {
            height: 300px;
        }

        .table {
            font-size: calc(var(--font-size-base) * 0.9);
        }

            .table thead th,
            .table tbody td {
                padding: 0.75rem;
            }
    }
</style>

<div class="d-flex flex-column area-admin">
    <!-- ══ HEADER ══ -->
    <div class="encabezado-admin">
        <h2>
            <i class="bi bi-activity"></i> Monitoreo en Tiempo Real
        </h2>
        <div class="navegacion-admin">
            <a asp-action="Paradas">Paradas</a>
            <a asp-action="Camiones">Camiones</a>
            <a asp-action="Conductores">Conductores</a>
            <a asp-action="Monitoreo" class="active">Monitoreo</a>
        </div>
    </div>

    <!-- ══ CONTENIDO ══ -->
    <div class="contenido-admin">
        <!-- MAPA -->
        <div class="contenedor-mapa">
            <div class="marcador-mapa">
                <i class="bi bi-map"></i>
                <p>Mapa integrado (SignalR Ready)</p>
                <small>Placeholder para integración con Google Maps o Leaflet</small>
            </div>
        </div>

        <!-- TABLA DE MONITOREO -->
        <h4 class="titulo-seccion">
            <i class="bi bi-speedometer2"></i> Estado de Camiones en Línea
        </h4>

        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>Camión</th>
                        <th>Conductor</th>
                        <th>Velocidad</th>
                        <th>Pasajeros</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>ABC-123</td>
                        <td>Juan Pérez</td>
                        <td>35 km/h</td>
                        <td>28/45</td>
                        <td><span class="insignia-estado insignia-ruta">En Ruta</span></td>
                    </tr>
                    <tr>
                        <td>XYZ-456</td>
                        <td>María López</td>
                        <td>42 km/h</td>
                        <td>35/50</td>
                        <td><span class="insignia-estado insignia-ruta">En Ruta</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>