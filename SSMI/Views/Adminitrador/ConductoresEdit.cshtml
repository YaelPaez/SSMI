@model List<SSMI.Models.Conductor>

@{
    ViewData["Title"] = "Gestión de Conductores";
    Layout = "~/Views/Shared/_UsuarioLayout.cshtml";
}

<style>
    /* ── Área principal ── */
    .area-admin {
        height: 85vh;
        background-color: #f0f2f5;
        overflow: hidden;
        transition: background-color .3s;
    }

    body.dark-mode .area-admin {
        background-color: #0d1117;
    }

    /* ── Encabezado ── */
    .encabezado-admin {
        background: linear-gradient(135deg, #1E3C54, #2a5580);
        color: white;
        padding: 1.5rem;
        box-shadow: 0 4px 15px rgba(30, 60, 84, 0.3);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    body.dark-mode .encabezado-admin {
        background: linear-gradient(135deg, #0d1117, #161b22);
        border-bottom: 2px solid rgba(0, 212, 255, 0.2);
    }

    .encabezado-admin h2 {
        margin: 0;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: calc(var(--font-size-base) * 1.8);
    }

    /* ── Navegación ── */
    .navegacion-admin {
        display: flex;
        gap: 0.5rem;
    }

        .navegacion-admin a {
            padding: 0.75rem 1.5rem;
            border-radius: 8px;
            text-decoration: none;
            color: white;
            background: rgba(255, 255, 255, 0.1);
            transition: all .3s;
            font-weight: 600;
        }

            .navegacion-admin a:hover {
                background: rgba(255, 255, 255, 0.2);
                transform: translateY(-2px);
            }

            .navegacion-admin a.active {
                background: #00d4ff;
                color: #1E3C54;
            }

    /* ── Contenido ── */
    .contenido-admin {
        flex-grow: 1;
        overflow-y: auto;
        padding: 1.5rem;
    }

    .titulo-seccion {
        color: #1E3C54;
        font-weight: 700;
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        font-size: calc(var(--font-size-base) * 1.5);
    }

    body.dark-mode .titulo-seccion {
        color: #e6edf3;
    }

    /* ── Tabla ── */
    .table {
        background: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,.08);
        margin-bottom: 2rem;
    }

    body.dark-mode .table {
        background: #161b22;
        box-shadow: 0 2px 8px rgba(0,0,0,.3);
    }

    .table thead {
        background-color: #f8f9fa;
        border-bottom: 2px solid #e9ecef;
    }

        .table thead th {
            color: #1E3C54;
            font-weight: 600;
            padding: 1rem;
            font-size: var(--font-size-base);
        }

    .table tbody td {
        padding: 1rem;
        vertical-align: middle;
        border-bottom: 1px solid #e9ecef;
        color: #1E3C54;
    }

    .table tbody tr:hover {
        background-color: #f8f9fa;
    }

    body.dark-mode .table thead {
        background-color: #0d1117;
        border-color: #30363d;
    }

        body.dark-mode .table thead th {
            color: #e6edf3;
        }

    body.dark-mode .table tbody td {
        border-color: #30363d;
        color: #e6edf3;
    }

    body.dark-mode .table tbody tr:hover {
        background-color: #0d1117;
    }

    /* ── Botones ── */
    .boton-admin {
        border: none;
        border-radius: 10px;
        padding: 0.75rem 1.5rem;
        font-weight: 600;
        font-size: var(--font-size-base);
        transition: all .3s;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
    }

    .boton-agregar {
        background-color: #1E3C54;
        color: white;
    }

        .boton-agregar:hover {
            background-color: #2a5580;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(30, 60, 84, 0.3);
            color: white;
        }

    /* Estilos extras para las alertas de estatus */
    .badge-estado {
        padding: 0.5rem 1rem;
        border-radius: 6px;
        font-weight: 600;
        font-size: 0.85rem;
    }

    /* ── Modal en modo oscuro ── */
    body.dark-mode .modal-content {
        background-color: #161b22;
        color: #e6edf3;
        border: 1px solid #30363d;
    }

    body.dark-mode .modal-header {
        border-bottom: 1px solid #30363d;
    }

    body.dark-mode .modal-footer {
        border-top: 1px solid #30363d;
    }

    body.dark-mode .modal-title {
        color: #e6edf3;
    }

    body.dark-mode .modal-body .form-label {
        color: #e6edf3;
    }

    body.dark-mode .modal-body .form-control {
        background-color: #0d1117;
        border-color: #30363d;
        color: #e6edf3;
    }

        body.dark-mode .modal-body .form-control::placeholder {
            color: #00d4ff;
            opacity: 0.7;
        }

        body.dark-mode .modal-body .form-control:focus {
            background-color: #0d1117;
            border-color: #00d4ff;
            box-shadow: 0 0 0 0.2rem rgba(0, 212, 255, 0.15);
        }

    body.dark-mode .btn-close {
        filter: invert(1);
    }

    body.dark-mode .modal-footer .btn-secondary {
        background-color: #30363d;
        border-color: #30363d;
        color: #e6edf3;
    }

    body.dark-mode .modal-footer .boton-agregar {
        background-color: #00d4ff;
        color: #1E3C54;
        font-weight: 700;
    }

        body.dark-mode .modal-footer .boton-agregar:hover {
            background-color: #00bcd4;
            box-shadow: 0 4px 12px rgba(0, 212, 255, 0.3);
        }

    /* ── Responsive ── */
    @@media (max-width: 768px) {
        .encabezado-admin {
            flex-direction: column;
            gap: 1rem;
        }

        .navegacion-admin {
            flex-wrap: wrap;
        }

        .contenido-admin {
            padding: 1rem;
        }

        .table {
            font-size: calc(var(--font-size-base) * 0.9);
        }

            .table thead th,
            .table tbody td {
                padding: 0.75rem;
            }
    }
</style>

<div class="d-flex flex-column area-admin">
    <div class="encabezado-admin">
        <h2>
            <i class="bi bi-people"></i> Gestión de Conductores
        </h2>
        <div class="navegacion-admin">
            <a asp-action="Paradas">Paradas</a>
            <a asp-action="Camiones">Camiones</a>
            <a asp-action="ConductoresIndex" class="active">Conductores</a>
            <a asp-action="Monitoreo">Monitoreo</a>
            <a asp-action="HistorialIncidencias">Incidencias</a>
        </div>
    </div>

    <div class="contenido-admin">
        @if (TempData["MensajeError"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["MensajeError"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.Error
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="mb-3">
            <button class="btn boton-admin boton-agregar" data-bs-toggle="modal" data-bs-target="#modalConductor">
                <i class="bi bi-person-plus"></i> Invitar Conductor
            </button>
        </div>

        <div class="table-responsive">
            <table class="table">
                <thead>
                    <tr>
                        <th>ID Usuario</th>
                        <th>Nombre</th>
                        <th>Apellidos</th>
                        <th>Empresa</th>
                        <th>Correo Electrónico</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        foreach (var cond in Model)
                        {
                            <tr>
                                <td class="text-muted small">@cond.Id</td>
                                <td><strong>@cond.Nombre</strong></td>
                                <td>
                                    @if (string.IsNullOrEmpty(cond.ApellidoPaterno) && string.IsNullOrEmpty(cond.ApellidoMaterno))
                                    {
                                        <span class="text-muted fst-italic small">Pendiente (Fase 2)</span>
                                    }
                                    else
                                    {
                                        <span>@cond.ApellidoPaterno @cond.ApellidoMaterno</span>
                                    }
                                </td>
                                <td>
                                    @if (string.IsNullOrEmpty(cond.Empresa))
                                    {
                                        <span class="text-muted fst-italic small">Pendiente</span>
                                    }
                                    else
                                    {
                                        <span>@cond.Empresa</span>
                                    }
                                </td>
                                <td>@cond.Email</td>
                                <td>
                                    @if (cond.Estado == "Pendiente")
                                    {
                                        <span class="badge bg-warning text-dark badge-estado">
                                            <i class="bi bi-clock-history me-1"></i> Pendiente Activar
                                        </span>
                                    }
                                    else if (cond.Estado == "Activo")
                                    {
                                        <span class="badge bg-success badge-estado">
                                            <i class="bi bi-check-circle me-1"></i> Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary badge-estado">@cond.Estado</span>
                                    }
                                </td>
                                <td>
                                    @if (cond.Estado != "Inactivo")
                                    {
                                        <form action="/Adminitrador/ConductoresDelete" method="post" onsubmit="return confirm('¿Estás seguro de que deseas inactivar a este conductor?');" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@cond.Id" />
                                            <button type="submit" class="btn btn-sm btn-danger d-inline-flex align-items-center gap-1" title="Inactivar Conductor">
                                                <i class="bi bi-person-x-fill"></i> Inactivar
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <form action="/Adminitrador/ConductoresActivar" method="post" onsubmit="return confirm('¿Estás seguro de que deseas reactivar a este conductor?');" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@cond.Id" />
                                            <button type="submit" class="btn btn-sm btn-success d-inline-flex align-items-center gap-1" title="Activar Conductor">
                                                <i class="bi bi-person-check-fill"></i> Activar
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-muted text-center py-4">
                                <i class="bi bi-people display-6 d-block mb-2"></i>
                                No hay conductores registrados en el sistema actualmente.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="modalConductor" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-person-plus-fill"></i> Invitar Conductor</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form action="/Adminitrador/ConductoresCreate" method="post" autocomplete="off">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="nombre" class="form-label">Nombre del Conductor</label>
                        <input type="text"
                               class="form-control"
                               id="nombre"
                               name="nombre"
                               placeholder="Ej: Juan"
                               required
                               pattern="^[a-zA-ZáéíóúÁÉÍÓÚñÑüÜ\s]+$"
                               title="El nombre solo puede contener letras y espacios."
                               oninput="this.value = this.value.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑüÜ\s]/g, '');">
                    </div>
                    <div class="mb-3">
                        <label for="email" class="form-label">Correo Electrónico</label>
                        <input type="email" class="form-control" id="email" name="email" placeholder="Ej: conductor@correo.com" required>
                    </div>
                    <small class="text-muted d-block mt-2">
                        <i class="bi bi-info-circle me-1"></i> El sistema generará una contraseña temporal segura y la enviará de inmediato por correo electrónico.
                    </small>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn boton-admin boton-agregar">Enviar Acceso</button>
                </div>
            </form>
        </div>
    </div>
</div>