@{
    ViewData["Title"] = "Mejor Ruta";
    Layout = "~/Views/Shared/_UsuarioLayout.cshtml";
}

<style>
    .contenido-perfil {
        flex-grow: 1;
        overflow-y: auto;
        padding: 1.5rem;
        transition: background .3s;
    }
</style>


<div class="d-flex app-viewport">
    <!-- ══ SIDEBAR ══ -->
    <div id="sidebarMenu" class="shadow">
        <div class="d-flex flex-column p-4 h-100">
            <h4 class="text-center mt-2 mb-4">SSMI</h4>
            <a asp-action="Index" class="nav-btn"><i class="bi bi-house-door"></i> Inicio</a>
            <a asp-action="Perfil" class="nav-btn"><i class="bi bi-person-circle"></i> Mi Perfil</a>
            <a asp-action="MejorRuta" class="nav-btn active"><i class="bi bi-map"></i> Mejor Ruta</a>
            <a asp-action="Comentarios" class="nav-btn"><i class="bi bi-chat-left-dots"></i> Comentarios</a>
            <div class="mt-auto">
                <a asp-action="Ayuda" class="nav-btn"><i class="bi bi-question-circle"></i> Ayuda</a>
                <a asp-action="AcercaDeNosotros" class="nav-btn"><i class="bi bi-info-square"></i> Acerca de nosotros</a>
            </div>
        </div>
    </div>

    <!-- ══ CONTENIDO PRINCIPAL ══ -->
    <div class="flex-grow-1 d-flex flex-column">
        <div class="p-3 d-flex align-items-center gap-3 border-bottom">
            <button id="btnToggleMenu" class="btn btn-dark rounded-circle shadow-sm" style="width: 45px; height: 45px;">
                <i class="bi bi-list"></i>
            </button>
            <h2 class="mb-0">Mejor Ruta</h2>
        </div>

        <div class="contenido-perfil d-flex justify-content-center align-items-center">
            <div class="card shadow-lg p-4 d-flex flex-column"
                 style="width: 100%; max-width: 650px; border-radius: 25px; background-color: white;">

                <div class="mb-3">
                    <input type="text" class="form-control rounded-pill bg-light border-0 p-3 shadow-sm"
                           placeholder="Ingresa tu destino" aria-label="Destino">
                </div>

                <div class="text-center d-flex align-items-center justify-content-center overflow-hidden"
                     style="border-radius: 15px; background-color: #fcfcfc; min-height: 200px; max-height: 350px;">
                    <img src="~/Imagenes/imgMejorRuta.png" alt="Mejor Ruta - Mapa de trayecto"
                         style="max-width: 100%; max-height: 100%; width: auto; height: auto; object-fit: contain;">
                </div>

                <div class="text-center mt-4">
                    <a asp-action="TrayectoIniciado" class="btn rounded-pill px-5 py-3 shadow fw-bold"
                       style="background-color: #b8e994; border: none; color: black; font-size: 1.2rem; min-width: 250px;">
                        Iniciar Trayecto
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>