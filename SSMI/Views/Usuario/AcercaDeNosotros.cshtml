@model SSMI.Models.Usuario

@{
    ViewData["Title"] = "Acerca de Nosotros";

    Layout = "~/Views/Shared/_UsuarioLayout.cshtml";
}

<style>
    /* ── Contenido acerca de ── */
    .contenido-acerca {
        flex-grow: 1;
        overflow-y: auto;
        padding: 40px;
    }

    /* ── Tarjetas de información ── */
    .tarjeta-acerca {
        background: white;
        border-radius: 20px;
        border: none;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        padding: 30px;
        margin-bottom: 20px;
    }

    .icono-caracteristica {
        font-size: 2rem;
        color: #1E3C54;
        margin-bottom: 15px;
    }

    .titulo-ssmi {
        color: #1E3C54;
    }

    /* ── Modo oscuro específico de esta vista ── */
    body.dark-mode .tarjeta-acerca {
        background: #161b22;
        color: #e6edf3;
    }

        body.dark-mode .tarjeta-acerca h4 {
            color: #e6edf3;
        }

        body.dark-mode .tarjeta-acerca p {
            color: #8b949e;
        }

    body.dark-mode .icono-caracteristica {
        color: #00d4ff;
    }

    body.dark-mode .titulo-ssmi {
        color: #e6edf3;
    }
</style>

<div class="menu-container d-flex app-viewport">

    <!-- ══ SIDEBAR ══ -->
    <div id="sidebarMenu" class="shadow">
        <div class="d-flex flex-column p-4 h-100">
            <h4 class="text-center mt-2 mb-4">SSMI</h4>
            <a asp-action="Index" class="nav-btn"><i class="bi bi-house-door"></i> Inicio</a>
            <a asp-action="Perfil" class="nav-btn"><i class="bi bi-person-circle"></i> Mi Perfil</a>
            <a asp-action="Configuracion" class="nav-btn"><i class="bi bi-gear"></i> Configuración</a>
            <a asp-action="Comentarios" class="nav-btn"><i class="bi bi-chat-left-dots"></i> Comentarios</a>
            <div class="mt-auto">
                <a asp-action="Ayuda" class="nav-btn"><i class="bi bi-question-circle"></i> Ayuda</a>
                <a asp-action="AcercaDeNosotros" class="nav-btn active"><i class="bi bi-info-square"></i> Acerca de nosotros</a>
            </div>
        </div>
    </div>

    <!-- ══ CONTENIDO ══ -->
    <div class="d-flex flex-column w-100">
        <div class="p-3">
            <button id="btnToggleMenu" class="btn rounded-circle shadow-sm">
                <i class="bi bi-list"></i>
            </button>
        </div>

        <div class="contenido-acerca">
            <div class="container-fluid">
                <div class="row mb-4">
                    <div class="col-12">
                        <h2 class="fw-bold titulo-ssmi">Sobre SSMI</h2>
                        <p class="text-muted lead">Revolucionando la movilidad urbana a través de datos y tecnología.</p>
                    </div>
                </div>

                <div class="row g-4">
                    <div class="col-md-6">
                        <div class="tarjeta-acerca h-100">
                            <i class="bi bi-rocket-takeoff icono-caracteristica"></i>
                            <h4>Misión</h4>
                            <p class="text-secondary">Proveer a los ciudadanos herramientas inteligentes para optimizar sus tiempos de traslado, utilizando rutas eficientes y seguras en el transporte público.</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="tarjeta-acerca h-100">
                            <i class="bi bi-eye icono-caracteristica"></i>
                            <h4>Visión</h4>
                            <p class="text-secondary">Convertirnos en la plataforma líder de movilidad inteligente, reduciendo el impacto ambiental y mejorando la calidad de vida urbana.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>