@model SSMI.Models.Usuario

@{

    Layout = "~/Views/Shared/_UsuarioLayout.cshtml";
}


<style>
    /* ── Contenido perfil ── */
    .contenido-perfil {
        flex-grow: 1;
        overflow-y: auto;
        padding: 1.5rem;
        transition: background .3s;
    }

    /* ── Avatar ── */
    .circulo-avatar {
        width: 110px;
        height: 110px;
        border-radius: 50%;
        background: linear-gradient(135deg, #1E3C54, #00d4ff);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1rem auto;
        box-shadow: 0 8px 25px rgba(0,212,255,.25);
        transition: box-shadow .3s;
    }

        .circulo-avatar svg {
            width: 58px;
            fill: #fff;
        }

    /* ── Nombre ── */
    .nombre-perfil {
        font-size: calc(var(--font-size-base, 1rem) * 1.45);
        font-weight: 800;
        color: #1E3C54;
        text-align: center;
        margin-bottom: .25rem;
        transition: color .3s;
    }

    .subtitulo-perfil {
        text-align: center;
        font-size: calc(var(--font-size-base, 1rem) * 0.85);
        color: #8b949e;
        margin-bottom: 1.75rem;
    }

    /* ── Tarjetas de información ── */
    .tarjeta-dato {
        background: #fff;
        border-radius: 16px;
        padding: 1rem 1.25rem;
        margin-bottom: .85rem;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
        display: flex;
        align-items: center;
        gap: 1rem;
        transition: background .3s, box-shadow .3s, transform .2s;
    }

        .tarjeta-dato:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0,0,0,.09);
        }

    .icono-dato {
        width: 42px;
        height: 42px;
        border-radius: 10px;
        background: rgba(0,212,255,.1);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #00d4ff;
        font-size: 1.1rem;
        flex-shrink: 0;
        transition: background .3s;
    }

    .etiqueta-dato {
        font-size: calc(var(--font-size-base, 1rem) * 0.72);
        text-transform: uppercase;
        letter-spacing: .1em;
        color: #8b949e;
        margin-bottom: .1rem;
        font-weight: 600;
    }

    .valor-dato {
        font-size: var(--font-size-base, 1rem);
        font-weight: 600;
        color: #1E3C54;
        transition: color .3s;
    }

        .valor-dato.vacio {
            color: #adb5bd;
            font-weight: 400;
            font-style: italic;
        }

    /* ── Viajes ── */
    .tarjeta-viajes {
        background: #fff;
        border-radius: 16px;
        padding: 1.25rem;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
        transition: background .3s;
    }

    .titulo-viajes {
        font-size: calc(var(--font-size-base, 1rem) * 0.72);
        text-transform: uppercase;
        letter-spacing: .1em;
        color: #8b949e;
        font-weight: 700;
        margin-bottom: .75rem;
    }

    .texto-vacio {
        color: #adb5bd;
        font-size: calc(var(--font-size-base, 1rem) * 0.88);
        font-style: italic;
    }

    /* ── Editar perfil ── */
    .tarjeta-editar-perfil {
        background: #fff;
        border-radius: 16px;
        padding: 1.25rem;
        margin-top: 1rem;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
        display: none;
    }

    body.dark-mode .tarjeta-editar-perfil {
        background: #161b22;
        box-shadow: 0 2px 12px rgba(0,0,0,.3);
    }

    .tarjeta-editar-perfil .form-label {
        color: #8b949e;
        font-size: calc(var(--font-size-base, 1rem) * 0.8);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .06em;
    }

    /* ── Botón editar ── */
    .boton-editar {
        background: linear-gradient(135deg, #1E3C54, #2a5580);
        color: #fff;
        border: none;
        border-radius: 50px;
        padding: .65rem 2rem;
        font-weight: 700;
        letter-spacing: .04em;
        width: 100%;
        margin-top: .5rem;
        transition: all .3s;
        font-size: var(--font-size-base, 1rem);
        cursor: pointer;
    }

        .boton-editar:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(30,60,84,.3);
            color: #fff;
        }

    /* ── Modo oscuro específico de esta vista ── */
    body.dark-mode .circulo-avatar {
        box-shadow: 0 8px 25px rgba(0,212,255,.4);
    }

    body.dark-mode .nombre-perfil {
        color: #e6edf3;
    }

    body.dark-mode .tarjeta-dato {
        background: #161b22;
        box-shadow: 0 2px 12px rgba(0,0,0,.3);
    }

        body.dark-mode .tarjeta-dato:hover {
            box-shadow: 0 6px 20px rgba(0,0,0,.45);
        }

    body.dark-mode .icono-dato {
        background: rgba(0,212,255,.14);
    }

    body.dark-mode .valor-dato {
        color: #e6edf3;
    }

    body.dark-mode .tarjeta-viajes {
        background: #161b22;
    }

    body.dark-mode .boton-editar {
        background: linear-gradient(135deg, rgba(0,212,255,.2), rgba(0,212,255,.1));
        border: 1px solid rgba(0,212,255,.35);
        color: #00d4ff;
    }

        body.dark-mode .boton-editar:hover {
            box-shadow: 0 6px 20px rgba(0,212,255,.2);
        }
}
@section Scripts {
    <script src="~/js/Pasajero/perfil.js" asp-append-version="true"></script>
}
</style>

<div class="menu-container d-flex app-viewport">

    <!-- ══ SIDEBAR ══ -->
    <div id="sidebarMenu" class="shadow">
        <div class="d-flex flex-column p-4 h-100">
            <h4 class="text-center mt-2 mb-4">SSMI</h4>
            <a asp-action="Index" class="nav-btn"><i class="bi bi-house-door"></i> Inicio</a>
            <a asp-action="Perfil" class="nav-btn active"><i class="bi bi-person-circle"></i> Mi Perfil</a>
            <a asp-action="Configuracion" class="nav-btn"><i class="bi bi-gear"></i> Configuración</a>
            <a asp-action="Comentarios" class="nav-btn"><i class="bi bi-chat-left-dots"></i> Comentarios</a>
            <div class="mt-auto">
                <a asp-action="Ayuda" class="nav-btn"><i class="bi bi-question-circle"></i> Ayuda</a>
                <a asp-action="AcercaDeNosotros" class="nav-btn"><i class="bi bi-info-square"></i> Acerca de nosotros</a>
                <a asp-controller="Login" asp-action="CerrarSesion" class="nav-btn"><i class="bi bi-box-arrow-right"></i> Cerrar Sesión</a>
            </div>
        </div>
    </div>

    <!-- ══ CONTENIDO ══ -->
    <div class="d-flex flex-column w-100 overflow-hidden">
        <div class="p-3">
            <button id="btnToggleMenu" class="btn rounded-circle shadow-sm">
                <i class="bi bi-list fs-5"></i>
            </button>
        </div>

        <div class="contenido-perfil">
            <div style="max-width:480px; margin:0 auto;">

                <div class="circulo-avatar">
                    <svg viewBox="0 0 24 24">
                        <path d="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z" />
                    </svg>
                </div>
                <div class="nombre-perfil">@(Model?.Nombres != null ? Model.Nombres.ToUpper() + " " + Model.Apellidos.ToUpper() : "Mi Perfil")</div>
                <div class="subtitulo-perfil">@(Model?.Correo ?? "usuario@ssmi.mx")</div>

                <div class="tarjeta-dato">
                    <div class="icono-dato"><i class="bi bi-person"></i></div>
                    <div>
                        <div class="etiqueta-dato">Nombre completo</div>
                        <div class="valor-dato @(Model?.Nombres == null ? "vacio" : "")">
                            @(Model?.Nombres != null ? Model.Nombres.ToUpper() + " " + Model.Apellidos.ToUpper() : "Sin datos")
                        </div>
                    </div>
                </div>

                <div class="tarjeta-dato">
                    <div class="icono-dato"><i class="bi bi-telephone"></i></div>
                    <div>
                        <div class="etiqueta-dato">Teléfono</div>
                        <div class="valor-dato @(Model?.Numtelefono == null ? "vacio" : "")">
                            @(Model?.Numtelefono ?? "Sin datos")
                        </div>
                    </div>
                </div>

                <div class="tarjeta-dato">
                    <div class="icono-dato"><i class="bi bi-calendar3"></i></div>
                    <div>
                        <div class="etiqueta-dato">Fecha de nacimiento</div>
                        <div class="valor-dato">
                            @(Model?.FechaNacimiento != default ? Model.FechaNacimiento.ToString("dd/MM/yyyy") : "Sin datos")
                        </div>
                    </div>
                </div>

                <div class="tarjeta-dato">
                    <div class="icono-dato"><i class="bi bi-gender-ambiguous"></i></div>
                    <div>
                        <div class="etiqueta-dato">Género</div>
                        <div class="valor-dato @(Model?.Genero == null ? "vacio" : "")">
                            @(Model?.Genero ?? "Sin datos")
                        </div>
                    </div>
                </div>

                <div class="tarjeta-dato">
                    <div class="icono-dato"><i class="bi bi-heart-pulse"></i></div>
                    <div>
                        <div class="etiqueta-dato">Discapacidad</div>
                        <div class="valor-dato @(Model?.Discapacidad == null ? "vacio" : "")">
                            @(Model?.Discapacidad ?? "Ninguna")
                        </div>
                    </div>
                </div>

                <div class="tarjeta-viajes">
                    <div class="titulo-viajes"><i class="bi bi-map me-2"></i>Mis viajes recientes</div>
                    <div class="texto-vacio">Aún no has registrado viajes.</div>
                </div>

                <button id="btnEditarPerfil" type="button" class="boton-editar mt-3">
                    <i class="bi bi-pencil-square me-2"></i>Editar perfil
                </button>

                <div id="cardEditarPerfil" class="tarjeta-editar-perfil">
                    <div class="titulo-viajes"><i class="bi bi-pencil me-2"></i>Actualizar mis datos</div>

                    <form asp-controller="Usuario" asp-action="ActualizarPerfil" method="post" class="mt-3">
                        @Html.AntiForgeryToken()

                        <div class="row g-3">
                            <div class="col-12 col-md-6">
                                <label class="form-label">Nombres</label>
                                <input asp-for="Nombres" class="form-control" value="@Model.Nombres" required
                                       pattern="^[a-zA-ZáéíóúÁÉÍÓÚñÑ ]+$" title="El nombre solo debe contener letras." />
                            </div>

                            <div class="col-12 col-md-6">
                                <label class="form-label">Apellidos</label>
                                <input asp-for="Apellidos" class="form-control" value="@Model.Apellidos" required
                                       pattern="^[a-zA-ZáéíóúÁÉÍÓÚñÑ ]+$" title="Los apellidos solo deben contener letras." />
                            </div>

                            <div class="col-12">
                                <label class="form-label">Teléfono</label>
                                <input asp-for="Numtelefono" class="form-control" value="@Model.Numtelefono" required
                                       type="tel" maxlength="10" minlength="10" pattern="^[0-9]{10}$"
                                       title="El teléfono debe tener exactamente 10 dígitos numéricos." />
                            </div>

                            <div class="col-12 col-md-6">
                                <label class="form-label">Fecha de nacimiento</label>
                                <input name="FechaNacimiento" type="date" class="form-control" required
                                       max="@DateTime.Today.AddYears(-18).ToString("yyyy-MM-dd")"
                                       value="@(Model?.FechaNacimiento != default ? Model.FechaNacimiento.ToString("yyyy-MM-dd") : string.Empty)"
                                       title="Debes ser mayor de 18 años." />
                            </div>

                            <div class="col-12 col-md-6">
                                <label class="form-label">Género</label>
                                <select asp-for="Genero" class="form-control" required>
                                    <option value="">Seleccione una opción...</option>
                                    <option value="Masculino">Masculino</option>
                                    <option value="Femenino">Femenino</option>
                                    <option value="Otro">Otro</option>
                                </select>
                            </div>

                            <div class="col-12">
                                <label class="form-label">Discapacidad</label>
                                <select asp-for="Discapacidad" class="form-control" required>
                                    <option value="Ninguna">Ninguna</option>
                                    <option value="Motriz">Motriz</option>
                                    <option value="Visual">Visual</option>
                                    <option value="Auditiva">Auditiva</option>
                                    <option value="Intelectual/Psicosocial">Intelectual / Psicosocial</option>
                                    <option value="Otra">Otra</option>
                                </select>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-3">
                            <button type="submit" class="btn btn-primary flex-grow-1" style="background-color:#1E3C54;border:none;">
                                Guardar cambios
                            </button>
                            <button id="btnCancelarEdicion" type="button" class="btn btn-outline-secondary">
                                Cancelar
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>