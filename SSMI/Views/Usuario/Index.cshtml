@section Scripts {
    <script>
        /* ── Toggle sidebar ── */
        document.addEventListener('DOMContentLoaded', function () {
            const btn     = document.getElementById('btnToggleMenu');
            const sidebar = document.getElementById('sidebarMenu');
            btn.addEventListener('click', function () {
                sidebar.style.marginLeft = sidebar.style.marginLeft === '0px' ? '-280px' : '0px';
            });

            /* ── Bottom Sheet Behavior ── */
            const bottomSheet = document.getElementById('bottomSheet');
            const handle = document.getElementById('handle');
            let startY = 0;
            let startHeight = 0;
            let isDragging = false;

            const PEEK_HEIGHT = 80;
            const FULL_HEIGHT = window.innerHeight * 0.65;

            if (bottomSheet && handle) {
                bottomSheet.classList.add('peek');
                bottomSheet.classList.remove('active');

                handle.addEventListener('click', (e) => {
                    e.stopPropagation();
                    toggleSheet();
                });

                function toggleSheet() {
                    if (bottomSheet.classList.contains('active')) {
                        collapseSheet();
                    } else {
                        expandSheet();
                    }
                }

                function expandSheet() {
                    bottomSheet.style.height = FULL_HEIGHT + 'px';
                    bottomSheet.classList.add('active');
                    bottomSheet.classList.remove('peek');
                }

                function collapseSheet() {
                    bottomSheet.style.height = PEEK_HEIGHT + 'px';
                    bottomSheet.classList.remove('active');
                    bottomSheet.classList.add('peek');
                }

                handle.addEventListener('mousedown', startDrag);
                handle.addEventListener('touchstart', startDrag);

                function startDrag(e) {
                    isDragging = true;
                    startY = e.type.includes('touch') ? e.touches[0].clientY : e.clientY;
                    startHeight = bottomSheet.offsetHeight;
                    bottomSheet.style.transition = 'none';
                }

                document.addEventListener('mousemove', moveDrag);
                document.addEventListener('touchmove', moveDrag);

                function moveDrag(e) {
                    if (!isDragging) return;
                    const currentY = e.type.includes('touch') ? e.touches[0].clientY : e.clientY;
                    const diff = startY - currentY;
                    const newHeight = Math.max(PEEK_HEIGHT, Math.min(FULL_HEIGHT, startHeight + diff));
                    bottomSheet.style.height = newHeight + 'px';
                }

                document.addEventListener('mouseup', endDrag);
                document.addEventListener('touchend', endDrag);

                function endDrag() {
                    if (!isDragging) return;
                    isDragging = false;
                    const currentHeight = bottomSheet.offsetHeight;
                    const midpoint = (PEEK_HEIGHT + FULL_HEIGHT) / 2;
                    bottomSheet.style.transition = 'height 0.4s cubic-bezier(0.4, 0, 0.2, 1)';
                    if (currentHeight < midpoint) {
                        collapseSheet();
                    } else {
                        expandSheet();
                    }
                }

                document.querySelector('.contenido-panel').addEventListener('touchstart', (e) => {
                    e.stopPropagation();
                });
            }
        });
    </script>

    <script src="/js/Pasajero/Mapa.js"></script>
}