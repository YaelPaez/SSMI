@model SSMI.Models.Usuario

@{
    ViewData["Title"] = "Explorar - SSMI";
    Layout = "~/Views/Shared/_UsuarioLayout.cshtml";
}

<style>
    /* ── Vista principal del mapa ── */
    .app-viewport {
        height: 100vh;
        background-color: #f0f2f5;
        overflow: hidden;
        transition: background-color .3s;
    }

    /* ── Sidebar inicio oculto ── */
    #sidebarMenu {
        margin-left: -280px;
    }

    /* ── Modo oscuro sidebar ── */
    body.dark-mode #sidebarMenu {
        background-color: #0d1117 !important;
        border-right: 1px solid rgba(0,212,255,.12);
    }

    body.dark-mode .nav-btn {
        color: rgba(200,220,240,.7);
    }

        body.dark-mode .nav-btn:hover {
            background: rgba(0,212,255,.08);
            color: #e6edf3;
        }

        body.dark-mode .nav-btn.active {
            background: rgba(0,212,255,.15) !important;
            color: #00d4ff !important;
            box-shadow: none;
        }

    body.dark-mode .app-viewport {
        background-color: #0d1117;
    }

    /* ── Buscador ── */
    .buscador-overlay {
        position: absolute;
        top: 20px;
        left: 20px;
        right: 20px;
        z-index: 10;
        max-width: 600px;
        margin: 0 auto;
        pointer-events: auto;
    }

    .grupo-buscador {
        background: white;
        border-radius: 50px;
        padding: 5px 15px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.15);
        display: flex;
        align-items: center;
        transition: background .3s;
    }

        .grupo-buscador input {
            border: none;
            padding: 10px;
            font-size: var(--font-size-base, 1rem);
            outline: none;
            width: 100%;
            background: transparent;
            color: inherit;
        }

    body.dark-mode .grupo-buscador {
        background: #161b22;
        box-shadow: 0 4px 20px rgba(0,0,0,.4);
    }

        body.dark-mode .grupo-buscador input {
            color: #e6edf3;
        }

            body.dark-mode .grupo-buscador input::placeholder {
                color: #8b949e;
            }

    /* ── Contenedor del mapa ── */
    .contenedor-mapa {
        flex-grow: 1;
        position: relative;
        overflow: hidden;
        background-color: #e5e3df;
        transition: background-color .3s;
    }

    body.dark-mode .contenedor-mapa {
        background-color: #161b22;
    }

    /* ── Mapa Leaflet ── */
    #map {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 1;
    }

    /* ── Botón localización ── */
    .boton-localizacion {
        position: absolute;
        bottom: 30px;
        right: 30px;
        z-index: 10;
        width: 50px;
        height: 50px;
        background: white;
        pointer-events: auto;
        transition: background .3s;
    }

    body.dark-mode .boton-localizacion {
        background: #161b22 !important;
    }

        body.dark-mode .boton-localizacion i {
            color: #00d4ff !important;
        }

    /* ── Botón toggle sidebar (específico de esta vista por el tamaño) ── */
    #btnToggleMenu {
        width: 50px;
        height: 50px;
        flex-shrink: 0;
    }

    body.dark-mode #btnToggleMenu {
        background-color: #0d1117;
    }

    /* ── Tarjeta paradas cercanas ── */
    .tarjeta-paradas-cercanas {
        position: absolute;
        bottom: 100px;
        right: 30px;
        width: 320px;
        max-height: 400px;
        border-radius: 12px;
        border: none;
        z-index: 15;
        background: white;
        overflow: hidden;
        display: none;
        flex-direction: column;
        animation: slideInRight 0.3s ease-out;
    }

        .tarjeta-paradas-cercanas.show {
            display: flex;
        }

        .tarjeta-paradas-cercanas .card-header {
            background: linear-gradient(135deg, #1E3C54 0%, #00d4ff 100%);
            color: white;
            padding: 12px 16px;
            border-bottom: none;
            font-weight: 600;
        }

            .tarjeta-paradas-cercanas .card-header i {
                margin-right: 8px;
            }

    .lista-paradas {
        max-height: 350px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
    }

    .elemento-parada {
        padding: 12px 16px;
        border-bottom: 1px solid #e0e0e0;
        cursor: pointer;
        transition: all 0.3s;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .elemento-parada:last-child {
            border-bottom: none;
        }

        .elemento-parada:hover {
            background-color: #f5f5f5;
            transform: translateX(5px);
        }

    .info-parada {
        flex: 1;
    }

    .nombre-parada {
        font-weight: 600;
        color: #1E3C54;
        margin-bottom: 4px;
        font-size: 0.95rem;
    }

    .distancia-parada {
        font-size: 0.85rem;
        color: #666;
        display: flex;
        gap: 12px;
    }

    .item-distancia-parada {
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .etiqueta-parada {
        background: #1E3C54;
        color: white;
        padding: 4px 8px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        white-space: nowrap;
    }

    body.dark-mode .tarjeta-paradas-cercanas {
        background: #161b22;
        color: #e6edf3;
    }

    body.dark-mode .elemento-parada {
        border-bottom-color: #30363d;
    }

        body.dark-mode .elemento-parada:hover {
            background-color: #0d1117;
        }

    body.dark-mode .nombre-parada {
        color: #00d4ff;
    }

    body.dark-mode .distancia-parada {
        color: #8b949e;
    }

    .lista-paradas::-webkit-scrollbar {
        width: 6px;
    }

    .lista-paradas::-webkit-scrollbar-track {
        background: transparent;
    }

    .lista-paradas::-webkit-scrollbar-thumb {
        background: #ddd;
        border-radius: 3px;
    }

        .lista-paradas::-webkit-scrollbar-thumb:hover {
            background: #999;
        }

    body.dark-mode .lista-paradas::-webkit-scrollbar-thumb {
        background: #30363d;
    }

        body.dark-mode .lista-paradas::-webkit-scrollbar-thumb:hover {
            background: #444;
        }

    /* ── Bottom Sheet ── */
    .panel-inferior {
        position: fixed;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 0;
        background: white;
        border-radius: 20px 20px 0 0;
        box-shadow: 0 -8px 30px rgba(0,0,0,0.2);
        z-index: 999;
        transition: height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

        .panel-inferior.active {
            height: 65vh;
        }

        .panel-inferior.peek {
            height: 80px;
        }

    .barra-arrastre {
        width: 50px;
        height: 5px;
        background: linear-gradient(90deg, transparent, #d0d0d0, transparent);
        border-radius: 10px;
        margin: 12px auto;
        cursor: grab;
        flex-shrink: 0;
        transition: background 0.3s;
    }

        .barra-arrastre:hover {
            background: linear-gradient(90deg, transparent, #00d4ff, transparent);
        }

        .barra-arrastre:active {
            cursor: grabbing;
        }

    .encabezado-panel {
        background: linear-gradient(135deg, #1E3C54 0%, #00d4ff 100%);
        color: white;
        padding: 14px 16px;
        font-weight: 600;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-shrink: 0;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .encabezado-panel-izquierda {
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .encabezado-panel-izquierda i {
            font-size: 20px;
        }

    .titulo-panel {
        font-size: 16px;
        font-weight: 700;
        letter-spacing: 0.5px;
    }

    .contenido-panel {
        overflow-y: auto;
        flex: 1;
        padding: 0;
    }

        .contenido-panel::-webkit-scrollbar {
            width: 6px;
        }

        .contenido-panel::-webkit-scrollbar-track {
            background: transparent;
        }

        .contenido-panel::-webkit-scrollbar-thumb {
            background: #ddd;
            border-radius: 3px;
        }

            .contenido-panel::-webkit-scrollbar-thumb:hover {
                background: #999;
            }

    .elemento-parada-nuevo {
        display: flex;
        gap: 12px;
        padding: 12px 16px;
        border-bottom: 1px solid #e5e5e5;
        transition: all 0.2s;
        cursor: pointer;
        align-items: flex-start;
    }

        .elemento-parada-nuevo:hover {
            background: linear-gradient(90deg, transparent, rgba(0,212,255,0.08), transparent);
        }

        .elemento-parada-nuevo:active {
            background: rgba(0,212,255,0.15);
        }

    .etiqueta-distancia-parada {
        background: #e74c3c;
        color: white;
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 12px;
        font-weight: 700;
        white-space: nowrap;
        flex-shrink: 0;
        margin-top: 2px;
        min-width: 50px;
        text-align: center;
    }

    .detalles-parada {
        flex: 1;
        display: flex;
        gap: 8px;
        min-width: 0;
    }

    .icono-izquierda-parada {
        color: #e74c3c;
        font-size: 18px;
        flex-shrink: 0;
        margin-top: 2px;
    }

    .texto-parada {
        flex: 1;
        min-width: 0;
    }

    .direccion-parada {
        font-size: 13px;
        color: #333;
        font-weight: 500;
        margin-bottom: 2px;
    }

    .rutas-parada {
        font-size: 12px;
        color: #666;
    }

    .acciones-parada {
        display: flex;
        gap: 6px;
        flex-shrink: 0;
    }

    .circulo-accion {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        border: none;
        background: transparent;
        color: #1E3C54;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        font-size: 16px;
    }

        .circulo-accion:hover {
            background: rgba(30,60,84,0.1);
            transform: scale(1.1);
        }

        .circulo-accion:active {
            background: rgba(0,212,255,0.2);
        }

    body.dark-mode .panel-inferior {
        background: #161b22;
        color: #e6edf3;
    }

    body.dark-mode .barra-arrastre {
        background: linear-gradient(90deg, transparent, #30363d, transparent);
    }

        body.dark-mode .barra-arrastre:hover {
            background: linear-gradient(90deg, transparent, #00d4ff, transparent);
        }

    body.dark-mode .elemento-parada-nuevo {
        border-bottom-color: #30363d;
    }

        body.dark-mode .elemento-parada-nuevo:hover {
            background: linear-gradient(90deg, transparent, rgba(0,212,255,0.15), transparent);
        }

    body.dark-mode .direccion-parada {
        color: #e6edf3;
    }

    body.dark-mode .rutas-parada {
        color: #8b949e;
    }

    body.dark-mode .circulo-accion {
        color: #00d4ff;
    }

        body.dark-mode .circulo-accion:hover {
            background: rgba(0,212,255,0.15);
        }

    body.dark-mode .contenido-panel::-webkit-scrollbar-thumb {
        background: #30363d;
    }

        body.dark-mode .contenido-panel::-webkit-scrollbar-thumb:hover {
            background: #444;
        }
</style>

