@model SSMI.Models.InicioSesionYRegistro

@{
    ViewData["Title"] = "Iniciar Sesión";
    ViewBag.HideHeader = false;
}

<style>

    /* ───────── VARIABLES ───────── */

    :root {
        --cian: #00d4ff;
        --azul-boton: #5b58ff;
        --fondo-oscuro: #0d1b2a;
        --fondo-secundario: #1b3a4b;
    }

    /* ───────── BODY ───────── */

    body {
        margin: 0;
        min-height: 100vh;
        padding: 30px 15px;
        font-family: 'Segoe UI', system-ui, sans-serif;
        background: linear-gradient(135deg, #0d1b2a 0%, #1b3a4b 100%);
        overflow-x: hidden;
    }

    /* ───────── CONTENEDOR PRINCIPAL ───────── */

    .contenedor-login {
        width: 100%;
        display: flex;
        justify-content: center;
        padding: 70px 15px 30px 15px;
        animation: aparecer 0.8s ease;
    }

    .tarjeta-login {
        width: 900px;
        max-width: 100%;
        min-height: 540px;
        border-radius: 28px;
        overflow: hidden;
        display: flex;
        backdrop-filter: blur(20px);
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.08);
        box-shadow: 0 20px 45px rgba(0,0,0,0.35);
    }

    /* ───────── DECORACIÓN IZQUIERDA ───────── */

    .decoracion-login {
        flex: 1;
        min-width: 320px;
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,0.03);
    }


    .contenido-decoracion {
        position: relative;
        z-index: 2;
        text-align: center;
        padding: 35px;
    }

    .contenido-decoracion h2 {
        font-size: 2.4rem;
        font-weight: 800;
        margin-bottom: 15px;
        color: white;
    }

    .contenido-decoracion p {
        color: rgba(255,255,255,0.75);
        line-height: 1.7;
        font-size: 1rem;
    }

    /* ───────── FORMULARIO ───────── */

    .contenedor-formulario {
        flex: 1;
        padding: 50px 40px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .titulo-formulario {
        text-align: center;
        margin-bottom: 35px;
    }

        .titulo-formulario h1 {
            color: white;
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 10px;
        }

        .titulo-formulario p {
            color: rgba(255,255,255,0.7);
            margin: 0;
        }

    /* ───────── INPUTS ───────── */

    .grupo-entrada {
        margin-bottom: 20px;
    }

    .entrada-personalizada {
        width: 100%;
        padding: 16px 18px;
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.12);
        background: rgba(255,255,255,0.06);
        color: white;
        font-size: 0.95rem;
        outline: none;
        transition: 0.3s ease;
        backdrop-filter: blur(10px);
        box-sizing: border-box;
    }

        .entrada-personalizada::placeholder {
            color: rgba(255,255,255,0.45);
        }

        .entrada-personalizada:focus {
            border-color: var(--cian);
            box-shadow: 0 0 15px rgba(0,212,255,0.25);
            background: rgba(255,255,255,0.08);
        }

    /* ───────── CAPTCHA ───────── */

    .fila-captcha {
        display: flex;
        gap: 15px;
        margin-bottom: 20px;
    }

    .columna-captcha {
        flex: 1;
    }

    .captcha-generado {
        background: rgba(0,0,0,0.25) !important;
        color: var(--cian) !important;
        border: 1px dashed rgba(0,212,255,0.5) !important;
        text-align: center;
        font-weight: bold;
        letter-spacing: 4px;
        cursor: not-allowed;
    }

    /* ───────── BOTÓN ───────── */

    .btn-personalizado {
        width: 100%;
        border: none;
        padding: 16px;
        border-radius: 16px;
        background: linear-gradient(135deg, #5b58ff, #00d4ff);
        color: white;
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: 1px;
        cursor: pointer;
        transition: 0.3s ease;
        box-shadow: 0 12px 25px rgba(0,0,0,0.25);
    }

        .btn-personalizado:hover {
            transform: translateY(-3px);
            box-shadow: 0 18px 30px rgba(0,0,0,0.35);
        }

    /* ───────── MENSAJES ───────── */

    .mensaje-error {
        margin-top: 18px;
        text-align: center;
        color: #ff7b7b;
        font-weight: 600;
    }

    /* ───────── ENLACES ───────── */

    .enlaces-footer {
        text-align: center;
        margin-top: 25px;
    }

        .enlaces-footer a {
            color: rgba(255,255,255,0.75);
            text-decoration: none;
            transition: 0.3s ease;
            font-size: 0.95rem;
        }

            .enlaces-footer a:hover {
                color: var(--cian);
            }

    /* ───────── RESPONSIVE ───────── */

    @@media (max-width: 900px) {

        .tarjeta-login {
            flex-direction: column;
        }

        .decoracion-login {
            min-height: 260px;
        }

        .contenedor-formulario {
            padding: 35px 25px;
        }

        .fila-captcha {
            flex-direction: column;
        }
    }

    @@keyframes aparecer {

        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* ───────── PANTALLA DE CARGA OPTIMIZADA ───────── */
    .overlay-carga {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(13, 27, 42, 0.45);
        backdrop-filter: blur(15px);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease;
    }

        .overlay-carga.activo {
            opacity: 1;
            pointer-events: auto;
        }

    .contenedor-loader {
        text-align: center;
    }

    .gif-carga {
        width: 180px;
        height: 180px;
        object-fit: contain;
        margin-bottom: 25px;
        mix-blend-mode: screen;
    }

    .texto-carga {
        color: white;
        font-size: 1.6rem;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-shadow: 0 0 15px rgba(0, 212, 255, 0.6);
        margin: 0;
    }

</style>

<div class="contenedor-login">

    <div class="tarjeta-login">

        <!-- PANEL IZQUIERDO -->

        <div class="decoracion-login">

            <div class="circulo circulo-1"></div>
            <div class="circulo circulo-2"></div>
            <div class="circulo circulo-3"></div>

            <div class="contenido-decoracion">

                <h2>Bienvenido</h2>

                <p>
                    Accede a tu cuenta para utilizar el sistema
                    inteligente de monitoreo de transporte público.
                </p>

            </div>

        </div>

        <!-- FORMULARIO -->

        <div class="contenedor-formulario">

            <div class="titulo-formulario">
                <h1>Iniciar Sesión</h1>
                <p>Ingresa tus credenciales para continuar</p>
            </div>

            <form asp-controller="Login"
                  asp-action="IniciarSesion"
                  method="post">

                <!-- CORREO -->

                <div class="grupo-entrada">

                    <input asp-for="Usuario.Correo"
                           type="email"
                           class="entrada-personalizada"
                           placeholder="Correo Electrónico"
                           required>

                </div>

                <!-- CONTRASEÑA -->

                <div class="grupo-entrada">

                    <input asp-for="Usuario.Contrasena"
                           type="password"
                           class="entrada-personalizada"
                           placeholder="Contraseña"
                           required>

                </div>

                <!-- CAPTCHA -->

                <div class="fila-captcha">

                    <div class="columna-captcha">

                        <input asp-for="Captcha.CaptchaGenerado"
                               type="text"
                               class="entrada-personalizada captcha-generado"
                               value="@Model.Captcha.CaptchaGenerado"
                               readonly>

                    </div>

                    <div class="columna-captcha">

                        <input asp-for="Captcha.Captcha"
                               type="text"
                               class="entrada-personalizada"
                               placeholder="Ingresar Captcha"
                               onpaste="return false"
                               oncopy="return false"
                               oncut="return false"
                               required>

                    </div>

                </div>

                <!-- BOTÓN -->

                <button type="submit"
                        class="btn-personalizado">

                    ENTRAR

                </button>

                <!-- ERROR -->
                @if (ViewBag.Error != null)
                {
                    <div class="mensaje-error">
                        @ViewBag.Error
                    </div>
                }

            </form>

            <!-- ENLACE -->

            <div class="enlaces-footer">

                <a asp-action="Registro">
                    ¿No tienes cuenta? Regístrate aquí
                </a>

            </div>

        </div>

    </div>

</div>

<div id="pantalla-carga" class="overlay-carga">
    <div class="contenedor-loader">
        <img src="~/Imagenes/loading.gif" alt="Cargando..." class="gif-carga" />
        <p class="texto-carga">Verificando credenciales...</p>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const formulario = document.querySelector("form");
        const loader = document.getElementById("pantalla-carga");

        if (formulario) {
            formulario.addEventListener("submit", function (event) {
                if (formulario.checkValidity()) {
                    loader.classList.add("activo");
                }
            });
        }
    });
</script>