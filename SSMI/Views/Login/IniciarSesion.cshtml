@model SSMI.Models.InicioSesionYRegistro

@{
    ViewData["Title"] = "Iniciar Sesión";
}

<style>
    body {
        background-color: #f0f2f5;
    }

    .login-container {
        background-color: #1E3C54;
        max-width: 420px;
        margin: 60px auto; 
        padding: 40px 30px;
        border-radius: 25px;
        box-shadow: 0 15px 35px rgba(30, 60, 84, 0.3);
    }

    .avatar-header {
        background-color: #ffffff;
        width: 100px;
        height: 100px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px auto;
        border: 4px solid rgba(255, 255, 255, 0.2);
    }

        .avatar-header svg {
            width: 60px;
            fill: #1E3C54;
        }

    .title h2 {
        color: #FFFFFF;
        text-align: center;
        font-weight: 800;
        letter-spacing: 2px;
        margin-bottom: 30px;
        font-size: 1.5rem;
        text-transform: uppercase;
    }

    .form-floating {
        margin-bottom: 1rem;
    }

        .form-floating > .form-control {
            background-color: rgba(255, 255, 255, 0.1) !important;
            border: 1px solid rgba(255, 255, 255, 0.2) !important;
            color: #ffffff !important;
            border-radius: 12px !important;
            height: 60px !important;
        }

            .form-floating > .form-control:focus {
                background-color: rgba(255, 255, 255, 0.15) !important;
                box-shadow: 0 0 0 0.25rem rgba(255, 255, 255, 0.1);
                border: 1px solid #ffffff !important;
            }

        .form-floating > label {
            color: rgba(255, 255, 255, 0.8) !important;
        }

    .no-select {
        background-color: #262a33 !important;
        border: 2px dashed #445666 !important;
        color: #00d4ff !important;
        text-align: center;
        font-weight: bold;
        letter-spacing: 5px;
        font-size: 1.3rem;
        cursor: not-allowed;
    }

    .btn-custom {
        background-color: #ffffff;
        color: #1E3C54;
        border: none;
        border-radius: 12px;
        padding: 14px;
        font-weight: 800;
        text-transform: uppercase;
        width: 100%;
        margin-top: 10px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    }

        .btn-custom:hover {
            background-color: #e1e1e1;
            transform: translateY(-2px);
        }

    .error-msg {
        color: #ff6b6b;
        text-align: center;
        font-size: 0.9rem;
        margin-top: 15px;
        font-weight: bold;
    }

    .footer-links {
        text-align: center;
        margin-top: 20px;
    }

        .footer-links a {
            color: rgba(255, 255, 255, 0.7);
            text-decoration: none;
            font-size: 0.85rem;
        }

            .footer-links a:hover {
                color: #00d4ff;
            }
</style>

<div class="login-container">
    <div class="avatar-header">
        <svg viewBox="0 0 24 24"><path d="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z" /></svg>
    </div>

    <div class="title">
        <h2>Bienvenido</h2>
    </div>

    <form asp-controller="Login" asp-action="IniciarSesion" method="post">
        
        <div class="form-floating mb-3">
            <input asp-for="Usuario.Correo" type="email" class="form-control" placeholder="nombre@ejemplo.com" required>
                <label>Correo Electrónico</label>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Usuario.Contrasena" type="password" class="form-control" placeholder="Password" required>
                    <label>Contraseña</label>
                </div>

                <div class="row g-2 mb-3">
                    <div class="col-6">
                        <div class="form-floating">
                            <input asp-for="Captcha.CaptchaGenerado" type="text" class="form-control no-select" value="@Model.Captcha.CaptchaGenerado" readonly>
                                <label>Captcha</label>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-floating">
                                <input asp-for="Captcha.Captcha" type="text" class="form-control" placeholder="Ingresa" required>
                                    <label>Ingresar</label>
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="btn-custom">Entrar</button>

                        @if (ViewBag.Error != null)
                        {
                            <div class="error-msg">
                                <i class="bi bi-exclamation-circle me-1"></i> @ViewBag.Error
                            </div>
                        }
                    </form>

                    <div class="footer-links">
                        <a asp-action="Registro">¿No tienes cuenta? Regístrate aquí</a>
                    </div>
                </div>