@model SSMI.Models.InicioSesionYRegistro

@{
    ViewData["Title"] = "Registro";
    ViewBag.HideHeader = false;
}

<style>

    /* ───────── VARIABLES ───────── */

    :root {
        --cian: #00d4ff;
        --azul-boton: #5b58ff;
        --fondo-oscuro: #0d1b2a;
        --fondo-secundario: #1b3a4b;
    }

    /* ───────── BODY ───────── */

    body {
        margin: 0;
        min-height: 100vh;
        padding: 30px 15px;
        font-family: 'Segoe UI', system-ui, sans-serif;
        background: linear-gradient(135deg, #0d1b2a 0%, #1b3a4b 100%);
        overflow-x: hidden;
    }

    /* ───────── CONTENEDOR PRINCIPAL ───────── */

    .contenedor-login {
        width: 100%;
        display: flex;
        justify-content: center;
        padding: 70px 15px 30px 15px;
        animation: aparecer 0.8s ease;
    }

    .tarjeta-login {
        width: 950px;
        max-width: 100%;
        border-radius: 28px;
        overflow: hidden;
        display: flex;
        backdrop-filter: blur(20px);
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.08);
        box-shadow: 0 20px 45px rgba(0,0,0,0.35);
    }

    /* ───────── DECORACIÓN IZQUIERDA ───────── */

    .decoracion-login {
        flex: 1;
        min-width: 320px;
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,0.03);
    }

    
    .contenido-decoracion {
        position: relative;
        z-index: 2;
        text-align: center;
        padding: 30px;
    }

        .contenido-decoracion h2 {
            font-size: 2.5rem;
            font-weight: 800;
            margin-bottom: 15px;
            color: white;
        }

        .contenido-decoracion p {
            color: rgba(255,255,255,0.75);
            line-height: 1.7;
            font-size: 1rem;
        }

    /* ───────── FORMULARIO ───────── */

    .contenedor-formulario {
        flex: 1.5;
        padding: 45px;
    }

    .titulo-formulario {
        text-align: center;
        margin-bottom: 30px;
    }

        .titulo-formulario h1 {
            color: white;
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 8px;
        }

        .titulo-formulario p {
            color: rgba(255,255,255,0.7);
            margin: 0;
        }

    /* ───────── FILAS ───────── */

    .fila-personalizada {
        display: flex;
        gap: 15px;
        margin-bottom: 15px;
        flex-wrap: wrap;
    }

    .columna-personalizada {
        flex: 1;
        min-width: 220px;
    }

    /* ───────── INPUTS ───────── */

    .entrada-personalizada {
        width: 100%;
        padding: 15px 18px;
        border-radius: 15px;
        border: 1px solid rgba(255,255,255,0.12);
        background: rgba(255,255,255,0.06);
        color: white;
        font-size: 0.95rem;
        outline: none;
        transition: 0.3s ease;
        backdrop-filter: blur(10px);
        box-sizing: border-box;
    }

        .entrada-personalizada::placeholder {
            color: rgba(255,255,255,0.45);
        }

        .entrada-personalizada:focus {
            border-color: var(--cian);
            box-shadow: 0 0 15px rgba(0,212,255,0.25);
            background: rgba(255,255,255,0.08);
        }

    select.entrada-personalizada {
        cursor: pointer;
    }

        select.entrada-personalizada option {
            background-color: #102331;
            color: white;
        }

    /* ───────── CAPTCHA ───────── */

    .captcha-generado {
        background: rgba(0,0,0,0.25) !important;
        color: var(--cian) !important;
        border: 1px dashed rgba(0,212,255,0.5) !important;
        text-align: center;
        font-weight: bold;
        letter-spacing: 4px;
        cursor: not-allowed;
    }

    /* ───────── CHECKBOX ───────── */

    .contenedor-politicas {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-top: 10px;
        margin-bottom: 25px;
        flex-wrap: wrap;
    }

        .contenedor-politicas input[type="checkbox"] {
            width: 18px;
            height: 18px;
            accent-color: var(--cian);
            cursor: pointer;
        }

        .contenedor-politicas a {
            color: rgba(255,255,255,0.85);
            text-decoration: none;
            font-size: 0.92rem;
            transition: 0.3s ease;
        }

            .contenedor-politicas a:hover {
                color: var(--cian);
            }

    /* ───────── BOTÓN ───────── */

    .btn-personalizado {
        width: 100%;
        border: none;
        padding: 16px;
        border-radius: 16px;
        background: linear-gradient(135deg, #5b58ff, #00d4ff);
        color: white;
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: 1px;
        cursor: pointer;
        transition: 0.3s ease;
        box-shadow: 0 12px 25px rgba(0,0,0,0.25);
    }

        .btn-personalizado:hover {
            transform: translateY(-3px);
            box-shadow: 0 18px 30px rgba(0,0,0,0.35);
        }

    /* ───────── MENSAJES ───────── */

    .mensaje-error {
        margin-top: 18px;
        text-align: center;
        color: #ff7b7b;
        font-weight: 600;
    }

    .validation-summary-errors ul {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .validation-summary-errors li {
        margin-bottom: 6px;
    }

    /* ───────── RESPONSIVE ───────── */

    @@media (max-width: 900px) {

        .tarjeta-login {
            flex-direction: column;
        }

        .decoracion-login {
            min-height: 220px;
        }

        .contenedor-formulario {
            padding: 35px 25px;
        }
    }

    @@keyframes aparecer {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

</style>

<div class="contenedor-login">

    <div class="tarjeta-login">

        <!-- PANEL IZQUIERDO -->

        <div class="decoracion-login">

            <div class="circulo circulo-1"></div>
            <div class="circulo circulo-2"></div>
            <div class="circulo circulo-3"></div>

            <div class="contenido-decoracion">
                <h2>SSMI</h2>

                <p style="text-align: justify;">

                    Crea tu cuenta para acceder al sistema inteligente
                    de monitoreo de transporte público.

                    <br><br><br>

                    • Usa únicamente letras en nombre y apellidos.<br>
                    • Ingresa un correo válido y un teléfono de 10 dígitos.<br>
                    • La contraseña debe contener entre 6 y 12 caracteres, y un caracter especial (#,!,$,%,&).<br>
                    • Debes ser mayor de edad y aceptar las políticas de privacidad.

                </p>
            </div>

        </div>

        <!-- FORMULARIO -->

        <div class="contenedor-formulario">

            <div class="titulo-formulario">
                <h1>Registro</h1>
                <p>Ingresa tus datos para continuar</p>
            </div>

            <div asp-validation-summary="All" class="mensaje-error"></div>
            <form asp-controller="Login" asp-action="Registro" method="post">

                <!-- FILA 1 -->

                <div class="fila-personalizada">

                    <div class="columna-personalizada">
                        <input asp-for="Usuario.Nombres"
                               type="text"
                               class="entrada-personalizada"
                               placeholder="Nombre(s)"
                               oninput="this.value=this.value.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑ\s]/g,'')"
                               required>
                    </div>

                    <div class="columna-personalizada">
                        <input asp-for="Usuario.Apellidos"
                               type="text"
                               class="entrada-personalizada"
                               placeholder="Apellido(s)"
                               oninput="this.value=this.value.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑ\s]/g,'')"
                               required>
                    </div>

                </div>

                <!-- FILA 2 -->

                <div class="fila-personalizada">

                    <div class="columna-personalizada">
                        <input asp-for="Usuario.Correo"
                               type="email"
                               class="entrada-personalizada"
                               placeholder="Correo Electrónico"
                               required>
                    </div>

                    <div class="columna-personalizada">
                        <input asp-for="Usuario.Numtelefono"
                               type="tel"
                               class="entrada-personalizada"
                               placeholder="Número Telefónico"
                               inputmode="numeric"
                               maxlength="10"
                               oninput="this.value=this.value.replace(/[^0-9]/g,'')"
                               required>
                    </div>

                </div>

                <!-- FILA 3 -->

                <div class="fila-personalizada">

                    <div class="columna-personalizada">
                        <input asp-for="Usuario.Contrasena"
                               type="password"
                               class="entrada-personalizada"
                               placeholder="Contraseña"
                               required>
                    </div>

                    <div class="columna-personalizada">

                        <select asp-for="Usuario.Genero"
                                class="entrada-personalizada"
                                required>

                            <option value="">Seleccionar Género</option>
                            <option value="Masculino">Masculino</option>
                            <option value="Femenino">Femenino</option>
                            <option value="Otro">Otro</option>
                            <option value="Prefiero no decir">Prefiero no decir</option>

                        </select>

                    </div>

                </div>

                <!-- FILA 4 -->

                <div class="fila-personalizada">

                    <div class="columna-personalizada" style="display: flex; flex-direction: column; align-items: center;">
                        <label asp-for="Usuario.FechaNacimiento" style="color: var(--cian); font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 8px; text-shadow: 0 0 10px rgba(0,212,255,0.4);">Fecha de nacimiento</label>
                        <input asp-for="Usuario.FechaNacimiento"
                               type="date"
                               class="entrada-personalizada"
                               onkeydown="return false"
                               required>
                        
                    </div>

                    <div class="columna-personalizada">
                        <label style="display: block; margin-bottom: 8px; font-size: 0.9rem; visibility: hidden;">
                            Discapacidad
                        </label>
                        <select asp-for="Usuario.Discapacidad"
                                class="entrada-personalizada">
                            <option value="" disabled selected hidden>Selecione una discapcidad</option>
                            <option value="Ninguna">Ninguna</option>
                            <option value="Motriz">Motriz</option>
                            <option value="Visual">Visual</option>
                            <option value="Auditiva">Auditiva</option>
                            <option value="Intelectual">Intelectual</option>
                            <option value="Psicosocial">Psicosocial</option>
                            <option value="Otra">Otra</option>

                        </select>

                    </div>

                </div>

                <!-- CAPTCHA -->

                <div class="fila-personalizada">

                    <div class="columna-personalizada">
                        <input asp-for="Captcha.CaptchaGenerado"
                               type="text"
                               class="entrada-personalizada captcha-generado"
                               value="@Model.Captcha.CaptchaGenerado"
                                                              oncopy="return false"
                               oncut="return false"
                               readonly>
                    </div>

                    <div class="columna-personalizada">
                        <input asp-for="Captcha.Captcha"
                               type="text"
                               class="entrada-personalizada"
                               placeholder="Ingresar Captcha"
                               onpaste="return false"
                               oncopy="return false"
                               oncut="return false"
                               required>
                    </div>

                </div>

                <!-- POLÍTICAS -->
                <div class="contenedor-politicas">
                    <input type="checkbox"
                           id="checkDefault"
                           required>
                    <a asp-controller="Home" asp-action="Privacy">
                        Acepto Políticas de Privacidad
                    </a>

                </div>
                <!-- BOTÓN -->

                <button type="submit" class="btn-personalizado">
                    REGISTRAR
                </button>

                <!-- ERROR -->
                @if (ViewBag.Error != null)
                {
                    <div class="mensaje-error">
                        @ViewBag.Error
                    </div>
                }

            </form>

        </div>

    </div>

</div>
