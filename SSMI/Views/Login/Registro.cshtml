@model SSMI.Models.InicioSesionYRegistro

@{
    ViewData["Title"] = "Registro";
}

<style>

    body {
        background-color: #f0f2f5;
    }

    .login-container {
        background-color: #1E3C54; 
        max-width: 450px;
        margin: 40px auto;
        padding: 40px 30px;
        border-radius: 25px;
        box-shadow: 0 15px 35px rgba(30, 60, 84, 0.3);
    }

    .form-floating {
        margin-bottom: 1rem;
    }

        .form-floating > .form-control,
        .form-floating > .form-select {
            background-color: rgba(255, 255, 255, 0.1) !important; 
            border: 1px solid rgba(255, 255, 255, 0.2) !important;
            color: #ffffff !important;
            border-radius: 12px !important;
            height: 60px !important;
        }

     
            .form-floating > .form-control:focus {
                background-color: rgba(255, 255, 255, 0.15) !important;
                box-shadow: 0 0 0 0.25rem rgba(255, 255, 255, 0.1);
                border: 1px solid #ffffff !important;
            }

            .form-select {
    background-color: #262a33 !important;
    color: #ffffff !important;
    border: 1px solid rgba(255, 255, 255, 0.2) !important;
}

        .form-floating > label {
            color: rgba(255, 255, 255, 0.8) !important;
            padding: 1rem 1.2rem !important;
        }
        .form-select option {
    background-color: #262a33; 
    color: #ffffff;
    padding: 10px;
}

    
    .no-select {
        background-color: #262a33 !important;
        border: 2px dashed #445666 !important;
        color: #00d4ff !important; 
        text-align: center;
        font-weight: bold;
        letter-spacing: 5px;
        font-size: 1.3rem;
    }

    .btn-custom {
        background-color: #ffffff;
        color: #1E3C54;
        border: none;
        border-radius: 12px;
        padding: 14px;
        font-weight: 800;
        text-transform: uppercase;
        width: 100%;
        margin-top: 20px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    }

        .btn-custom:hover {
            background-color: #e1e1e1;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0,0,0,0.3);
        }

    .avatar-header {
        background-color: #ffffff;
        width: 100px;
        height: 100px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px auto;
        border: 4px solid rgba(255, 255, 255, 0.2);
    }

        .avatar-header svg {
            width: 60px;
            fill: #1E3C54;
        }

    .title h2 {
        color: #FFFFFF;
        text-align: center;
        font-weight: 800;
        letter-spacing: 2px;
        margin-bottom: 25px;
        font-size: 1.5rem;
    }

    .form-check-label {
        color: rgba(255, 255, 255, 0.9);
        font-size: 0.9rem;
    }

        .form-check-label a {
            color:  #1E3C54;
            text-decoration: none;
            font-weight: bold;
        }

            .form-check-label a:hover {
                text-decoration: underline;
            }

    .form-check-input:checked {
        background-color: #151E4F;
        border-color: #081038;
    }
</style>


<div class="login-container">
    <div class="menu-icon">
        <span></span><span></span><span></span>
    </div>

    <div class="avatar-header">
        <div class="avatar-circle">
            <svg viewBox="0 0 24 24"><path d="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z" /></svg>
        </div>
    </div>
    <div class=" title">
        <h2>REGISTRO</h2>

    </div>

    <form asp-controller="Login" asp-action="Registro" method="post">

        <div class="form-floating mb-2">
            <input asp-for="Usuario.Nombres" type="text" class="form-control" placeholder="Nombre(s)" required>
            <label asp-for="Usuario.Nombres">Nombre(s)</label>
        </div>

        <div class="form-floating mb-2">
            <input asp-for="Usuario.Apellidos" type="text" class="form-control" placeholder="Apellido(s)" required>
            <label asp-for="Usuario.Apellidos">Apellido(s)</label>
        </div>

        <div class="form-floating mb-2">
            <input asp-for="Usuario.Correo" type="email" class="form-control" placeholder="nombre@ejemplo.com" required>
            <label asp-for="Usuario.Correo">Correo Electrónico</label>
        </div>

        <div class="form-floating mb-2">
            <input asp-for="Usuario.Numtelefono" type="tel" class="form-control" placeholder="Teléfono" required>
            <label asp-for="Usuario.Numtelefono">Teléfono</label>
        </div>

        <div class="form-floating mb-2">
            <input asp-for="Usuario.Contrasena" type="password" class="form-control" placeholder="Password" required>
            <label asp-for="Usuario.Contrasena">Contraseña</label>
        </div>

        <div class="form-floating mb-2">
            <select asp-for="Usuario.Genero" class="form-select">
                <option value="">Seleccionar</option>
                <option value="Masculino">Masculino</option>
                <option value="Femenino">Femenino</option>
                <option value="Otro">Otro</option>
                <option value="Prefiero no decir">Prefiero no decir</option>
            </select>
            <label asp-for="Usuario.Genero">Genero</label>
        </div>

        <div class="form-floating mb-2">
            <input asp-for="Usuario.FechaNacimiento" type="date" class="form-control">
            <label asp-for="Usuario.FechaNacimiento">Fecha de nacimiento</label>
        </div>

        <div class="form-floating mb-2">
            <select asp-for="Usuario.Discapacidad" class="form-select">
                <option value="Ninguna" selected>Ninguna</option>
                <option value="Motriz">Motriz</option>
                <option value="Visual">Visual</option>
                <option value="Auditiva">Auditiva</option>
                <option value="Intelectual">Intelectual</option>
                <option value="Psicosocial">Psicosocial</option>
                <option value="Otra">Otra</option>
            </select>
            <label asp-for="Usuario.Discapacidad">Discapacidad</label>
        </div>

        <div class="row g-2 mt-2">
            <div class="col-6">
                <div class="form-floating">
                    <input asp-for="Captcha.CaptchaGenerado" type="text" class="form-control no-select" value="@Model.Captcha.CaptchaGenerado" readonly>
                    <label>Captcha</label>
                </div>
            </div>
            <div class="col-6">
                <div class="form-floating">
                    <input asp-for="Captcha.Captcha" type="text" class="form-control" placeholder="Ingresa" required>
                    <label>Ingresar</label>
                </div>
            </div>
        </div>

        <div class="form-check mt-3">
            <input type="checkbox" class="form-check-input" id="checkDefault" required>
            <a asp-controller="Home" asp-action="Privacy" class="form-check-label" id="checkDefault">
                <i ></i> Acepto Politicas de Privacidad
            </a>
        </div>

        <button type="submit" class="btn-custom">REGISTRAR</button>

    </form>
</div>
