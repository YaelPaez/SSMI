@{
    ViewData["Title"] = "Política de Privacidad";
    ViewBag.HideHeader = false;

}

<style>

    :root {
        --cian: #00d4ff;
        --azul1: #0f2027;
        --azul2: #203a43;
        --azul3: #2c5364;
        --glass: rgba(255,255,255,.06);
        --borde: rgba(255,255,255,.08);
        --texto: #e6edf3;
        --texto2: #b8c7d1;
    }

    body {
        background: linear-gradient(135deg, var(--azul1), var(--azul2), var(--azul3));
        min-height: 100vh;
    }

    /* CARD */

    .tarjeta-privacidad {
        background: var(--glass);
        backdrop-filter: blur(16px);
        border: 1px solid var(--borde);
        border-radius: 28px;
        box-shadow: 0 10px 40px rgba(0,0,0,.3);
        overflow: hidden;
    }

    /* TITULOS */

    .titulo-seccion {
        color: white;
        font-weight: 800;
        position: relative;
        padding-bottom: 10px;
        margin-bottom: 20px;
    }

        .titulo-seccion::after {
            content: '';
            position: absolute;
            left: 0;
            bottom: 0;
            width: 55px;
            height: 4px;
            background: var(--cian);
            border-radius: 10px;
        }

    /* ICONO */

    .icono-circular {
        width: 70px;
        height: 70px;
        border-radius: 20px;
        background: rgba(0,212,255,.12);
        color: var(--cian);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        border: 1px solid rgba(0,212,255,.25);
    }

    /* CAJAS */

    .caja-info {
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.06);
        border-left: 4px solid var(--cian);
        border-radius: 18px;
        padding: 20px;
        height: 100%;
    }

    /* LISTA */

    .list-group-item {
        background: rgba(255,255,255,.04);
        color: var(--texto);
        border-color: rgba(255,255,255,.05);
    }

    /* TABLA */

    .table {
        color: var(--texto2);
        margin-bottom: 0;
    }

        .table thead {
            background: rgba(0,212,255,.12);
        }

        .table th {
            color: white;
            border: none;
        }

        .table td {
            background: rgba(255,255,255,.03);
            border-color: rgba(255,255,255,.05);
        }

    /* TEXTO */

    h1, h2, h3, h4, h5,
    .fw-bold,
    strong {
        color: white !important;
    }

    p, li, td, .text-muted, .text-secondary {
        color: var(--texto2) !important;
    }

    /* BOTONES */

    .btn {
        border: none;
        transition: .25s;
    }

        .btn:hover {
            transform: translateY(-2px);
        }

</style>

<div class="container py-5" style="max-width: 780px;">

    <div class="card tarjeta-privacidad">
        <div class="card-body p-4 p-md-5">
            <div class="text-center mb-5">
                <div class="icono-circular mx-auto shadow">
                    <i class="bi bi-shield-lock-fill"></i>
                </div>
                <h1 class="display-6 fw-bold text-dark">Política de Privacidad</h1>
                <p class="text-muted">Actualizado: Marzo 2026 • Versión 2.0</p>
            </div>

            <div class="mb-5">
                <h3 class="titulo-seccion">1. Introducción</h3>
                <p class="text-secondary lead">
                    En <strong>SSMI</strong>, nuestra prioridad es mejorar tu movilidad urbana de forma segura y sostenible.
                </p>
                <p>
                    Al utilizar nuestra aplicación de rutas y transporte público, aceptas las prácticas descritas en esta política,
                    diseñada para proteger tu información personal mientras optimizamos tus trayectos cotidianos.
                </p>
            </div>

            <div class="mb-5">
                <h3 class="titulo-seccion">2. Información que recopilamos</h3>
                <div class="row g-4 mt-1">
                    <div class="col-md-6">
                        <div class="caja-info shadow-sm">
                            <h5 class="fw-bold text-dark"><i class="bi bi-person-badge me-2"></i>Registro</h5>
                            <ul class="text-muted small">
                                <li>Nombre completo</li>
                                <li>Correo y teléfono verificado</li>
                                <li>Género y fecha de nacimiento</li>
                                <li class="text-primary fw-bold">Preferencia de discapacidad</li>
                            </ul>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="caja-info shadow-sm" style="border-left-color: #00d4ff;">
                            <h5 class="fw-bold text-dark"><i class="bi bi-geo-alt me-2"></i>Actividad</h5>
                            <ul class="text-muted small">
                                <li>Geolocalización en tiempo real</li>
                                <li>Historial de rutas consultadas</li>
                                <li>Modelo de dispositivo y SO</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mb-5">
                <h3 class="titulo-seccion">3. Uso de la información</h3>
                <div class="list-group list-group-flush border rounded-3 overflow-hidden">
                    <div class="list-group-item d-flex gap-3 p-3">
                        <i class="bi bi-lightning-fill text-warning"></i>
                        <div><strong>Optimización:</strong> Rutas más rápidas y menos congestionadas.</div>
                    </div>
                    <div class="list-group-item d-flex gap-3 p-3">
                        <i class="bi bi-graph-up-arrow text-success"></i>
                        <div><strong>Análisis:</strong> Estimación de tráfico y demanda de transporte.</div>
                    </div>
                    <div class="list-group-item d-flex gap-3 p-3">
                        <i class="bi bi-bell-fill text-danger"></i>
                        <div><strong>Avisos:</strong> Notificaciones sobre retrasos o cambios en rutas.</div>
                    </div>
                </div>
            </div>

            <div class="mb-5">
                <h3 class="titulo-seccion">4. Permisos</h3>
                <div class="table-responsive">
                    <table class="table table-borderless rounded-3 overflow-hidden">
                        <thead style="background-color: #1E3C54; color: white;">
                            <tr>
                                <th class="p-3">Permiso</th>
                                <th class="p-3">Necesidad</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="border-bottom">
                                <td class="p-3"><strong>Ubicación</strong></td>
                                <td class="p-3 text-muted">Esencial para el cálculo de rutas y tiempos.</td>
                            </tr>
                            <tr class="border-bottom">
                                <td class="p-3"><strong>Conexión</strong></td>
                                <td class="p-3 text-muted">Para sincronizar datos de tráfico en vivo.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="p-4 rounded-4 mt-5 text-center shadow-sm" style="background: rgba(255,255,255,.05); border:1px solid rgba(255,255,255,.08);">
                <h4 class="fw-bold mb-3">¿Tienes alguna duda?</h4>
                <p class="small mb-4 text-white-50">Nuestro equipo de soporte está disponible para explicarte el manejo de tus datos.</p>
                <a href="mailto:code.revolution08gmail.com" class="btn px-4 py-2 fw-bold" style="color: #1E3C54; border-radius: 10px;">
                    <i class="bi bi-envelope-fill me-2"></i>Escríbenos ahora
                </a>
            </div>

            <!-- Botón regresar abajo -->
            <div class="text-center mt-5">
                <a asp-controller="Login" asp-action="Registro" class="btn px-5 py-3 fw-bold shadow-sm" style="background-color: #00d4ff; color: #1E3C54; border-radius: 50px;">
                    <i class="bi bi-arrow-left me-2"></i> Volver al Registro
                </a>
            </div>
        </div>
    </div>
</div>