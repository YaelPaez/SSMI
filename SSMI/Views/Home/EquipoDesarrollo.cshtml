@{
    ViewData["Title"] = "Code Revolution";
    ViewBag.HideHeader = true;

}

<style>
    /* ── Contenido ── */
    .contenido-equipo {
        flex-grow: 1;
        overflow-y: auto;
        padding: 40px;
        background: #f4f6f9;
        transition: background .3s;
    }

    .contenedor-equipo {
        max-width: 1100px;
        margin: auto;
    }

    /* ── Hero ── */
    .hero-equipo {
        text-align: center;
        margin-bottom: 3rem;
    }

        .hero-equipo h2 {
            font-size: 2.5rem;
            font-weight: 800;
            color: #1E3C54;
            margin-bottom: 1rem;
            transition: color .3s;
        }

            .hero-equipo h2 span {
                color: #00d4ff;
            }

        .hero-equipo p {
            font-size: 1.1rem;
            color: #6b7280;
            max-width: 700px;
            margin: 0 auto;
            line-height: 1.7;
            transition: color .3s;
        }

    /* ── Cuadrícula de tarjetas ── */
    .cuadricula-info {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1.5rem;
        margin-bottom: 3rem;
    }

    .tarjeta-info {
        background: #fff;
        padding: 2rem;
        border-radius: 20px;
        box-shadow: 0 8px 25px rgba(0,0,0,0.06);
        border-top: 5px solid #1E3C54;
        transition: all .3s;
    }

        .tarjeta-info:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 30px rgba(0,0,0,0.1);
        }

        .tarjeta-info h3 {
            color: #1E3C54;
            margin-bottom: 0.75rem;
            font-size: 1.3rem;
            font-weight: 700;
            transition: color .3s;
        }

        .tarjeta-info p {
            color: #4a5568;
            line-height: 1.7;
            transition: color .3s;
        }

    .tarjeta-ancha {
        grid-column: 1 / -1;
    }

    /* ── Sección equipo ── */
    .seccion-equipo {
        margin-top: 1rem;
    }

    .titulo-equipo {
        text-align: center;
        font-size: 2rem;
        font-weight: 800;
        color: #1E3C54;
        margin-bottom: 2.5rem;
        transition: color .3s;
    }

    .cuadricula-equipo {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 2rem;
    }

    .tarjeta-miembro {
        background: #fff;
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 8px 25px rgba(0,0,0,0.06);
        text-align: center;
        transition: all .3s;
    }

        .tarjeta-miembro:hover {
            transform: translateY(-8px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.12);
        }

    .caja-foto {
        width: 100%;
        height: 220px;
        background: #e8ecf1;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        color: #1E3C54;
        border-bottom: 3px solid #00d4ff;
        transition: all .3s;
    }

    .info-miembro {
        padding: 1.5rem;
    }

        .info-miembro h4 {
            color: #1E3C54;
            font-size: 1.05rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
            transition: color .3s;
        }

        .info-miembro p {
            color: #6b7280;
            font-size: 0.9rem;
            margin-bottom: 0.25rem;
            transition: color .3s;
        }

    /* ── Modo oscuro ── */
    body.dark-mode .contenido-equipo {
        background: #0d1117;
    }

    body.dark-mode .hero-equipo h2 {
        color: #e6edf3;
    }

    body.dark-mode .hero-equipo p {
        color: #8b949e;
    }

    body.dark-mode .tarjeta-info {
        background: #161b22;
        border-top-color: #00d4ff;
        box-shadow: 0 8px 25px rgba(0,0,0,0.3);
    }

        body.dark-mode .tarjeta-info h3 {
            color: #e6edf3;
        }

        body.dark-mode .tarjeta-info p {
            color: #8b949e;
        }

    body.dark-mode .titulo-equipo {
        color: #e6edf3;
    }

    body.dark-mode .tarjeta-miembro {
        background: #161b22;
        box-shadow: 0 8px 25px rgba(0,0,0,0.3);
    }

        body.dark-mode .tarjeta-miembro:hover {
            box-shadow: 0 15px 35px rgba(0,0,0,0.5);
        }

    body.dark-mode .caja-foto {
        background: #21262d;
        color: #00d4ff;
        border-bottom-color: #00d4ff;
    }

    body.dark-mode .info-miembro h4 {
        color: #e6edf3;
    }

    body.dark-mode .info-miembro p {
        color: #8b949e;
    }

    /* ── Responsive ── */
    @@media (max-width: 768px) {
        .hero-equipo h2 {
            font-size: 1.8rem;
        }

        .cuadricula-info {
            grid-template-columns: 1fr;
        }

        .tarjeta-ancha {
            grid-column: auto;
        }

        .cuadricula-equipo {
            grid-template-columns: 1fr;
        }
    }
</style>

