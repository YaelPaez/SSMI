@{
    ViewData["Title"] = "Equipo de Desarrollo";
    ViewBag.HideHeader = false;

}

<style>

    :root {
        --cian: #00d4ff;
        --azul-oscuro: #0f2027;
        --azul-secundario: #203a43;
        --azul-card: rgba(255,255,255,0.08);
        --texto: #e6edf3;
        --texto-sec: #b8c7d1;
        --borde: rgba(255,255,255,0.1);
    }

    body {
        background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
        min-height: 100vh;
    }

    .contenido-equipo {
        flex-grow: 1;
        overflow-y: auto;
        padding: 40px;
    }

    .contenedor-equipo {
        max-width: 1100px;
        margin: auto;
    }

    /* HERO */

    .hero-equipo {
        text-align: center;
        margin-bottom: 3rem;
    }

        .hero-equipo h2 {
            font-size: 2.7rem;
            font-weight: 800;
            color: white;
            margin-bottom: 1rem;
        }

            .hero-equipo h2 span {
                color: var(--cian);
            }

    /* TITULO */

    .titulo-equipo {
        text-align: center;
        font-size: 2rem;
        font-weight: 800;
        color: white;
        margin-bottom: 2.5rem;
    }

    /* GRID */

    .cuadricula-equipo {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 2rem;
    }

    /* TARJETAS */

    .tarjeta-miembro {
        background: var(--azul-card);
        backdrop-filter: blur(14px);
        border: 1px solid var(--borde);
        border-radius: 24px;
        overflow: hidden;
        transition: .3s;
        box-shadow: 0 10px 30px rgba(0,0,0,.25);
    }

        .tarjeta-miembro:hover {
            transform: translateY(-8px);
            border-color: var(--cian);
            box-shadow: 0 15px 40px rgba(0,212,255,.2);
        }

    /* FOTO */

    .caja-foto {
        width: 100%;
        height: 280px;
        background: white;
        border-bottom: 1px solid rgba(255,255,255,.08);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

        .caja-foto img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

    /* INFO */

    .info-miembro {
        padding: 1.5rem;
        text-align: center;
    }

        .info-miembro h4 {
            color: white;
            font-size: 1.1rem;
            font-weight: 700;
            margin-bottom: .7rem;
        }

        .info-miembro p {
            color: var(--texto-sec);
            margin-bottom: .3rem;
            font-size: .95rem;
        }

    /* RESPONSIVE */

    @@media (max-width:768px) {

        .hero-equipo h2 {
            font-size: 2rem;
        }

        .cuadricula-equipo {
            grid-template-columns: 1fr;
        }
    }

</style>

