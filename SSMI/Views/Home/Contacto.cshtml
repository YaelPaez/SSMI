@model SSMI.Models.Contacto

@{
    ViewData["Title"] = "Contacto";
    ViewBag.HideHeader = false;
}

<style>

    /* ───────── VARIABLES ───────── */

    :root {
        --cian: #00d4ff;
        --azul-boton: #5b58ff;
        --fondo-oscuro: #0d1b2a;
        --fondo-secundario: #1b3a4b;
    }

    /* ───────── BODY ───────── */

    body {
        margin: 0;
        min-height: 100vh;
        padding: 30px 15px;
        font-family: 'Segoe UI', system-ui, sans-serif;
        background: linear-gradient(135deg, #0d1b2a 0%, #1b3a4b 100%);
        overflow-x: hidden;
    }

    /* ───────── CONTENEDOR PRINCIPAL ───────── */

    .contenedor-contacto {
        width: 100%;
        display: flex;
        justify-content: center;
        padding: 70px 15px 30px 15px;
        animation: aparecer 0.8s ease;
    }

    .tarjeta-contacto {
        width: 950px;
        max-width: 100%;
        min-height: 580px;
        border-radius: 28px;
        overflow: hidden;
        display: flex;
        backdrop-filter: blur(20px);
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.08);
        box-shadow: 0 20px 45px rgba(0,0,0,0.35);
    }

    /* ───────── PANEL IZQUIERDO ───────── */

    .decoracion-contacto {
        flex: 1;
        min-width: 320px;
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,0.03);
    }

    .contenido-decoracion {
        position: relative;
        z-index: 2;
        text-align: center;
        padding: 35px;
    }

 

    .contenido-decoracion h2 {
        font-size: 2.3rem;
        font-weight: 800;
        margin-bottom: 15px;
        color: white;
    }

    .contenido-decoracion p {
        color: rgba(255,255,255,0.75);
        line-height: 1.7;
        font-size: 1rem;
    }

    /* ───────── FORMULARIO ───────── */

    .contenedor-formulario {
        flex: 1;
        padding: 50px 40px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .titulo-formulario {
        text-align: center;
        margin-bottom: 35px;
    }

        .titulo-formulario h1 {
            color: white;
            font-size: 2rem;
            font-weight: 800;
            margin-bottom: 10px;
        }

        .titulo-formulario p {
            color: rgba(255,255,255,0.7);
            margin: 0;
        }

    /* ───────── INPUTS ───────── */

    .grupo-entrada {
        margin-bottom: 20px;
    }

    .entrada-personalizada {
        width: 100%;
        padding: 16px 18px;
        border-radius: 16px;
        border: 1px solid rgba(255,255,255,0.12);
        background: rgba(255,255,255,0.06);
        color: white;
        font-size: 0.95rem;
        outline: none;
        transition: 0.3s ease;
        backdrop-filter: blur(10px);
        box-sizing: border-box;
    }

        .entrada-personalizada::placeholder {
            color: rgba(255,255,255,0.45);
        }

        .entrada-personalizada:focus {
            border-color: var(--cian);
            box-shadow: 0 0 15px rgba(0,212,255,0.25);
            background: rgba(255,255,255,0.08);
        }

    textarea.entrada-personalizada {
        resize: none;
        min-height: 150px;
    }

    /* ───────── BOTÓN ───────── */

    .btn-personalizado {
        width: 100%;
        border: none;
        padding: 16px;
        border-radius: 16px;
        background: linear-gradient(135deg, #5b58ff, #00d4ff);
        color: white;
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: 1px;
        cursor: pointer;
        transition: 0.3s ease;
        box-shadow: 0 12px 25px rgba(0,0,0,0.25);
    }

        .btn-personalizado:hover {
            transform: translateY(-3px);
            box-shadow: 0 18px 30px rgba(0,0,0,0.35);
        }

    /* ───────── MENSAJES ───────── */

    .mensaje-exito {
        margin-top: 18px;
        text-align: center;
        color: #8dffb1;
        font-weight: 600;
    }

    .mensaje-error {
        margin-top: 18px;
        text-align: center;
        color: #ff7b7b;
        font-weight: 600;
    }

    /* ───────── RESPONSIVE ───────── */

    @@media (max-width: 900px) {

        .tarjeta-contacto {
            flex-direction: column;
        }

        .decoracion-contacto {
            min-height: 260px;
        }

        .contenedor-formulario {
            padding: 35px 25px;
        }
    }

    @@keyframes aparecer {

        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

</style>

<div class="contenedor-contacto">

    <div class="tarjeta-contacto">

        <!-- PANEL IZQUIERDO -->

        <div class="decoracion-contacto">

            <div class="contenido-decoracion">

                <h2>Contactanos</h2>

                <p>
                    ¿Tienes alguna duda, problemas o sugerencias?
                    Contactanos por este medio
                </p>

            </div>

        </div>

        <!-- FORMULARIO -->

        <div class="contenedor-formulario">

            <div class="titulo-formulario">

                <h1>Formulario de Contacto</h1>

            </div>

            <form asp-action="Contacto"
                  asp-controller="Home"
                  method="post">

                <!-- NOMBRE -->

                <div class="grupo-entrada">

                    <input asp-for="Nombre"
                           type="text"
                           class="entrada-personalizada"
                           placeholder="Nombre"
                           oninput="this.value=this.value.replace(/[^a-zA-ZáéíóúÁÉÍÓÚñÑ\s]/g,'')"
                           required />

                </div>

                <!-- CORREO -->

                <div class="grupo-entrada">

                    <input asp-for="Correo"
                           type="email"
                           class="entrada-personalizada"
                           placeholder="Correo Electrónico"
                           required />

                </div>

                <!-- MENSAJE -->

                <div class="grupo-entrada">

                    <textarea asp-for="Mensaje"
                              class="entrada-personalizada"
                              placeholder="Escribe tu mensaje"
                              required></textarea>

                </div>

                <!-- BOTÓN -->

                <button type="submit"
                        class="btn-personalizado">

                    ENVIAR MENSAJE

                </button>

                <!-- MENSAJES -->
                @if (ViewBag.Exito != null)
                {
                    <div class="mensaje-exito">
                        @ViewBag.Exito
                    </div>
                }

                @if (ViewBag.Error != null)
                {
                    <div class="mensaje-error">
                        @ViewBag.Error
                    </div>
                }

            </form>

        </div>

    </div>

</div>