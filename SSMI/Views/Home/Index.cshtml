
@{
    ViewData["Title"] = "Home Page";
    ViewBag.HideHeader = false;

}
<style>
    /* ── Variables y Base ── */
    :root {
        --cian: #00d4ff;
        --azul-boton: #5b58ff;
        --fondo-oscuro: #0d1b2a;
    }

    body {
        margin: 0;
        font-family: 'Segoe UI', system-ui, sans-serif;
        background: linear-gradient(135deg, #0d1b2a 0%, #1b3a4b 100%);
        color: white;
        min-height: calc(100vh - 80px);
    }

    .seccion-nosotros {
        display: flex;
        align-items: center;
        justify-content: space-between;
        min-height: 100vh;
        max-width: 1200px;
        margin: 0 auto;
        padding: 2rem;
        gap: 3rem;
    }

    /* ── Texto e Izquierda ── */
    .bloque-texto {
        flex: 1;
        animation: aparecerIzquierda 1s ease;
    }

        .bloque-texto h1 {
            font-size: 3.5rem;
            font-weight: 900;
            margin-bottom: 1rem;
        }

        .bloque-texto p {
            font-size: 1.1rem;
            color: rgba(255, 255, 255, 0.7);
            margin-bottom: 2rem;
        }

    /* ── Botones ── */
    .grupo-botones {
        display: flex;
        flex-direction: column;
        gap: 12px;
        align-items: flex-start;
    }

    .fila-botones {
        display: flex;
        gap: 12px;
        width: 100%;
    }

    .btn-principal {
        background: var(--azul-boton);
        color: white;
        padding: 12px 25px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 700;
        transition: 0.3s;
        text-align: center;
        flex: 1;
        backdrop-filter: blur(10px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.15);
    }

    .btn-secundario {
        background: rgba(255,255,255,0.1);
        border: 1px solid rgba(255,255,255,0.2);
        color: white;
        padding: 12px 25px;
        border-radius: 8px;
        text-decoration: none;
        font-weight: 600;
        transition: 0.3s;
        text-align: center;
        flex: 1;
        backdrop-filter: blur(10px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.15);
    }

    .btn-equipo {
        color: var(--cian);
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 600;
        margin-top: 10px;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-principal:hover, .btn-secundario:hover {
        transform: translateY(-3px);
    }

    .btn-equipo:hover {
        text-decoration: underline;
    }

    /* ── Contenedor de Imagen (Derecha) ── */
    .bloque-visual {
        flex: 1.2;
        animation: aparecerDerecha 1.2s ease;
    }

    .contenedor-imagen {
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .mi-imagen {
        width: 115%;
        max-width: 650px;
        height: auto;
        object-fit: contain;
        filter: drop-shadow(0 0 20px rgba(0,212,255,0.25));
        /* Animación */
        animation: flotar 4s ease-in-out infinite;
        /* Hace que se vea más integrada */
        filter: drop-shadow(0 10px 25px rgba(0,0,0,0.25));
        transition: 0.3s;
    }

    /* ── Animaciones ── */
    @@keyframes aparecerIzquierda {
        from {
            opacity: 0;
            transform: translateX(-40px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@keyframes aparecerDerecha {
        from {
            opacity: 0;
            transform: translateX(40px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@keyframes flotar {
        0% {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-5px);
        }

        100% {
            transform: translateY(0px);
        }
    }

    /* ── Responsive ── */
    @@media (max-width: 992px) {
        .seccion-nosotros {
            flex-direction: column;
            text-align: center;
            padding-top: 4rem;
        }

        .grupo-botones {
            align-items: center;
        }

        .contenedor-imagen {
            height: 300px;
        }
    }
</style>

<div class="seccion-nosotros">
    <div class="bloque-texto">
        <h1>SSMASDDSAI</h1>
        <p>
            Con esta aplicacion, pretendemos conectar a las personas con su destino a través de tecnología inteligente. <br />
            Rutas optimizadas, transporte en tiempo real y un enfoque sostenible.
        </p>

        <div class="grupo-botones">
            <div class="fila-botones">
                <a asp-controller="Login" asp-action="Registro" class="btn-principal">Registrarse</a>
                <a asp-controller="Login" asp-action="IniciarSesion" class="btn-secundario">Iniciar Sesión</a>
            </div>
        </div>
    </div>
    <div class="bloque-visual">
        <div class="contenedor-imagen">
            <img src="~/Imagenes/imgLogoAplicacionSinFondo.png" alt="Logo Aplicacion" class="mi-imagen" />
        </div>
    </div>
</div>